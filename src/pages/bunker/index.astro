---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Le Bunker — Assistant IA Survivalix" description="Pose tes questions à l'assistant Survivalix. Conseils personnalisés, ton décalé, expertise survie.">

  <div class="bunker-header">
    <div class="bunker-label">// INTELLIGENCE ARTIFICIELLE //</div>
    <h1>Le Bunker</h1>
    <p class="bunker-desc">Pose tes questions à l'assistant Survivalix. Il connaît ses classiques, il a de l'humour, et il ne te jugera pas si tu ne sais pas ce qu'est un kit 72h.</p>
  </div>

  <div class="bunker-container">

    <div class="bunker-toolbar" id="bunkerToolbar" style="display: none;">
      <div class="toolbar-right">
        <button class="new-chat-btn" onclick="resetConversation()">// Nouvelle conversation //</button>
        <div class="memory-note">// mémoire du bunker : ~3h //</div>
      </div>
    </div>

    <div class="bunker-chat" id="chat">
      <div class="message message-assistant">
        <div class="message-avatar">
          <svg viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg" width="28" height="28">
            <rect x="12" y="20" width="40" height="32" rx="2" stroke="#F5A623" stroke-width="1.5"/>
            <rect x="20" y="28" width="8" height="6" rx="1" stroke="#F5A623" stroke-width="1.5"/>
            <rect x="36" y="28" width="8" height="6" rx="1" stroke="#F5A623" stroke-width="1.5"/>
            <line x1="24" y1="42" x2="40" y2="42" stroke="#F5A623" stroke-width="1.5" stroke-linecap="round"/>
            <line x1="32" y1="12" x2="32" y2="20" stroke="#F5A623" stroke-width="1.5"/>
            <circle cx="32" cy="10" r="3" stroke="#F5A623" stroke-width="1.5"/>
            <line x1="16" y1="36" x2="8" y2="36" stroke="#F5A623" stroke-width="1.5" stroke-linecap="round"/>
            <line x1="48" y1="36" x2="56" y2="36" stroke="#F5A623" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
        </div>
        <div class="message-content">
          <div class="message-name">// BUNKER IA //</div>
          <p>Citoyen, bienvenue. Je suis l'assistant Survivalix — formé pour répondre à toutes tes questions sur la survie, le prepping et l'autonomie. Sans jargon inutile, avec un peu d'humour. Qu'est-ce qui t'amène ?</p>
        </div>
      </div>
    </div>

    <div class="bunker-suggestions" id="suggestions">
      <div class="suggestions-label">// QUESTIONS FRÉQUENTES //</div>
      <div class="suggestions-grid">
        <button class="suggestion" onclick="askQuestion('Par où commencer le prepping quand on est débutant ?')">Par où commencer ?</button>
        <button class="suggestion" onclick="askQuestion('Quel est le minimum pour un kit 72h en appartement ?')">Kit 72h minimum ?</button>
        <button class="suggestion" onclick="askQuestion('Combien d\'eau stocker pour une famille de 4 personnes ?')">Stock d'eau famille</button>
        <button class="suggestion" onclick="askQuestion('Quels aliments stocker en priorité et pour combien de temps ?')">Aliments à stocker</button>
        <button class="suggestion" onclick="askQuestion('Comment préparer son logement pour une coupure d\'électricité longue ?')">Coupure électricité</button>
        <button class="suggestion" onclick="askQuestion('Quelle radio acheter pour les urgences ?')">Radio d'urgence</button>
      </div>
    </div>

    <div class="bunker-input-zone">
      <textarea
        id="userInput"
        placeholder="Pose ta question au Bunker..."
        rows="1"
        onkeydown="handleKeyDown(event)"
        oninput="autoResize(this)"
      ></textarea>
      <button id="sendBtn" onclick="sendMessage()">
        <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
          <line x1="4" y1="12" x2="20" y2="12" stroke="#0d0d0d" stroke-width="2" stroke-linecap="round"/>
          <polyline points="14,6 20,12 14,18" stroke="#0d0d0d" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>
    </div>

    <div class="bunker-status" id="bunkerStatus">
      <div class="status-dots">
        <span></span><span></span><span></span>
      </div>
      <span class="status-text">Le Bunker analyse ta question...</span>
    </div>

  </div>

</Layout>

<script is:inline>
  const STORAGE_KEY = 'survivalix_bunker_chat';
  const EXPIRATION_MS = 3 * 60 * 60 * 1000; // 3 heures

  let messages = [];
  let isLoading = false;

  function avatarSVG() {
    return `<svg viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg" width="28" height="28">
      <rect x="12" y="20" width="40" height="32" rx="2" stroke="#F5A623" stroke-width="1.5"/>
      <rect x="20" y="28" width="8" height="6" rx="1" stroke="#F5A623" stroke-width="1.5"/>
      <rect x="36" y="28" width="8" height="6" rx="1" stroke="#F5A623" stroke-width="1.5"/>
      <line x1="24" y1="42" x2="40" y2="42" stroke="#F5A623" stroke-width="1.5" stroke-linecap="round"/>
      <line x1="32" y1="12" x2="32" y2="20" stroke="#F5A623" stroke-width="1.5"/>
      <circle cx="32" cy="10" r="3" stroke="#F5A623" stroke-width="1.5"/>
      <line x1="16" y1="36" x2="8" y2="36" stroke="#F5A623" stroke-width="1.5" stroke-linecap="round"/>
      <line x1="48" y1="36" x2="56" y2="36" stroke="#F5A623" stroke-width="1.5" stroke-linecap="round"/>
    </svg>`;
  }

  function askQuestion(question) {
    document.getElementById('userInput').value = question;
    sendMessage();
  }

  function handleKeyDown(e) {
    if (e.key === 'Enter' && !e.shiftKey) {
      e.preventDefault();
      sendMessage();
    }
  }

  function autoResize(el) {
    el.style.height = 'auto';
    el.style.height = Math.min(el.scrollHeight, 200) + 'px';
  }

  function setStatus(visible) {
    const status = document.getElementById('bunkerStatus');
    status.style.display = visible ? 'flex' : 'none';
  }

  function addMessage(role, content) {
    const chat = document.getElementById('chat');
    const div = document.createElement('div');
    div.className = `message message-${role}`;

    if (role === 'assistant') {
      div.innerHTML = `
        <div class="message-avatar">${avatarSVG()}</div>
        <div class="message-content">
          <div class="message-name">// BUNKER IA //</div>
          ${content.split('\n\n').map(p => `<p>${p.replace(/\n/g, '<br/>')}</p>`).join('')}
        </div>
      `;
    } else {
      div.innerHTML = `
        <div class="message-content message-content-user">
          <p>${content}</p>
        </div>
      `;
    }

    chat.appendChild(div);
    chat.scrollTop = chat.scrollHeight;
  }

  function saveConversation() {
    try {
      const payload = {
        messages: messages,
        timestamp: Date.now()
      };
      localStorage.setItem(STORAGE_KEY, JSON.stringify(payload));
    } catch (e) {
      // localStorage indisponible (navigation privée, quota plein) — on ignore silencieusement
    }
  }

  function clearConversation() {
    try {
      localStorage.removeItem(STORAGE_KEY);
    } catch (e) {}
  }

  function updateToolbarVisibility() {
    const toolbar = document.getElementById('bunkerToolbar');
    toolbar.style.display = messages.length > 0 ? 'flex' : 'none';
  }

  function resetConversation() {
    clearConversation();
    messages = [];
    document.getElementById('chat').innerHTML = '';
    addMessage('assistant', "Citoyen, bienvenue. Je suis l'assistant Survivalix — formé pour répondre à toutes tes questions sur la survie, le prepping et l'autonomie. Sans jargon inutile, avec un peu d'humour. Qu'est-ce qui t'amène ?");
    document.getElementById('suggestions').style.display = 'block';
    updateToolbarVisibility();
  }

  function restoreConversation() {
    let saved;
    try {
      const raw = localStorage.getItem(STORAGE_KEY);
      if (!raw) return;
      saved = JSON.parse(raw);
    } catch (e) {
      return;
    }

    if (!saved || !Array.isArray(saved.messages) || saved.messages.length === 0) return;

    const age = Date.now() - (saved.timestamp || 0);
    if (age > EXPIRATION_MS) {
      clearConversation();
      return;
    }

    // Conversation valide : on la recharge dans l'UI
    messages = saved.messages;
    document.getElementById('chat').innerHTML = '';

    messages.forEach(m => addMessage(m.role, m.content));

    document.getElementById('suggestions').style.display = 'none';
    updateToolbarVisibility();
  }

  async function sendMessage() {
    if (isLoading) return;
    const input = document.getElementById('userInput');
    const text = input.value.trim();
    if (!text) return;

    input.value = '';
    input.style.height = 'auto';
    isLoading = true;

    document.getElementById('sendBtn').disabled = true;
    document.getElementById('suggestions').style.display = 'none';

    addMessage('user', text);
    messages.push({ role: 'user', content: text });
    saveConversation();
    updateToolbarVisibility();

    setStatus(true);

    try {
      const response = await fetch('/api/bunker', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ messages: messages })
      });

      const data = await response.json();
      const reply = (data.content || [])
        .filter(block => block.type === 'text')
        .map(block => block.text)
        .join('\n\n');

      setStatus(false);
      addMessage('assistant', reply || "Le Bunker n'a pas pu formuler de réponse, réessaie ta question autrement.");
      messages.push({ role: 'assistant', content: reply });
      saveConversation();

    } catch (error) {
      setStatus(false);
      addMessage('assistant', 'Connexion au bunker interrompue. Vérifie ta connexion et réessaie.');
    }

    isLoading = false;
    document.getElementById('sendBtn').disabled = false;
  }

  restoreConversation();
</script>

<style>
  .bunker-header {
    text-align: center;
    padding: 3rem 0 2rem;
    border-bottom: 1px solid #1a1a1a;
    margin-bottom: 2rem;
  }

  .bunker-label {
    font-family: 'Oswald', sans-serif;
    font-size: 0.75rem;
    color: #6B7C45;
    letter-spacing: 4px;
    margin-bottom: 1rem;
  }

  .bunker-header h1 {
    font-family: 'Special Elite', cursive;
    font-size: clamp(2rem, 6vw, 3.5rem);
    color: #F5A623;
    letter-spacing: 4px;
    margin-bottom: 1rem;
  }

  .bunker-desc {
    font-family: 'Oswald', sans-serif;
    font-size: 1rem;
    color: #ffffff;
    opacity: 0.7;
    font-weight: 300;
    max-width: 600px;
    margin: 0 auto;
  }

  .bunker-container {
    max-width: 800px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .bunker-toolbar {
    display: flex;
    justify-content: flex-end;
  }

  .toolbar-right {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 0.4rem;
  }

  .memory-note {
    font-family: 'Oswald', sans-serif;
    font-size: 0.65rem;
    letter-spacing: 1px;
    color: #555;
    font-style: italic;
  }

  .new-chat-btn {
    font-family: 'Oswald', sans-serif;
    font-size: 0.75rem;
    letter-spacing: 1px;
    color: #6B7C45;
    background: none;
    border: 1px solid #2a2a2a;
    padding: 0.5rem 0.9rem;
    cursor: pointer;
    transition: all 0.2s;
  }

  .new-chat-btn:hover {
    color: #F5A623;
    border-color: #F5A623;
  }

  .bunker-chat {
    display: flex;
    flex-direction: column;
    gap: 1.2rem;
    min-height: 100px;
    overflow-y: auto;
    padding: 0.5rem 0;
    scrollbar-width: thin;
    scrollbar-color: #333 #0d0d0d;
  }

  .message {
    display: flex;
    gap: 0.8rem;
    align-items: flex-start;
  }

  .message-user { flex-direction: row-reverse; }

  .message-avatar {
    width: 36px;
    height: 36px;
    min-width: 36px;
    min-height: 36px;
    flex-shrink: 0;
    border: 1px solid #F5A623;
    padding: 4px;
    background-color: #0d0d0d;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .message-avatar svg {
    width: 28px !important;
    height: 28px !important;
    max-width: 28px;
    max-height: 28px;
    display: block;
  }

  .message-content {
    background-color: #111;
    border: 1px solid #1e1e1e;
    border-left: 3px solid #F5A623;
    padding: 0.8rem 1rem;
    flex: 1;
    min-width: 0;
  }

  .message-content-user {
    background-color: #1a1a0d;
    border-left-color: #6B7C45;
  }

  .message-name {
    font-family: 'Oswald', sans-serif;
    font-size: 0.65rem;
    color: #F5A623;
    letter-spacing: 3px;
    margin-bottom: 0.5rem;
  }

  .message-content p {
    font-family: 'Oswald', sans-serif;
    font-size: 0.92rem;
    color: #ffffff;
    opacity: 0.9;
    line-height: 1.8;
    margin-bottom: 0.6rem;
    font-weight: 300;
    word-wrap: break-word;
  }

  .message-content p:last-child { margin-bottom: 0; }

  /* STATUS */
  .bunker-status {
    display: none;
    align-items: center;
    gap: 0.8rem;
    padding: 0.8rem 1rem;
    background-color: #111;
    border: 1px solid #1e1e1e;
    border-left: 3px solid #F5A623;
  }

  .status-dots {
    display: flex;
    gap: 5px;
    align-items: center;
    flex-shrink: 0;
  }

  .status-dots span {
    width: 6px;
    height: 6px;
    background-color: #F5A623;
    border-radius: 50%;
    animation: dot 1.2s infinite;
  }

  .status-dots span:nth-child(2) { animation-delay: 0.2s; }
  .status-dots span:nth-child(3) { animation-delay: 0.4s; }

  @keyframes dot {
    0%, 60%, 100% { opacity: 0.2; transform: scale(0.8); }
    30% { opacity: 1; transform: scale(1); }
  }

  .status-text {
    font-family: 'Oswald', sans-serif;
    font-size: 0.82rem;
    color: #F5A623;
    letter-spacing: 1px;
    font-weight: 300;
    font-style: italic;
  }

  .suggestions-label {
    font-family: 'Oswald', sans-serif;
    font-size: 0.7rem;
    color: #6B7C45;
    letter-spacing: 3px;
    margin-bottom: 0.8rem;
  }

  .suggestions-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.6rem;
  }

  @media (min-width: 600px) {
    .suggestions-grid { grid-template-columns: repeat(3, 1fr); }
  }

  .suggestion {
    font-family: 'Oswald', sans-serif;
    font-size: 0.78rem;
    color: #ffffff;
    background: none;
    border: 1px solid #222;
    padding: 0.6rem 0.8rem;
    cursor: pointer;
    text-align: left;
    letter-spacing: 0.5px;
    transition: all 0.2s;
    line-height: 1.4;
  }

  .suggestion:hover {
    border-color: #F5A623;
    color: #F5A623;
    background-color: #111;
  }

  .bunker-input-zone {
    display: flex;
    border: 1px solid #333;
    border-bottom: 3px solid #F5A623;
    background-color: #111;
    align-items: flex-end;
  }

  .bunker-input-zone:focus-within { border-color: #F5A623; }

  #userInput {
    flex: 1;
    background: none;
    border: none;
    outline: none;
    font-family: 'Oswald', sans-serif;
    font-size: 1rem;
    font-weight: 300;
    color: #ffffff;
    padding: 1rem 1.2rem;
    resize: none;
    line-height: 1.6;
    min-height: 54px;
    max-height: 200px;
  }

  #userInput::placeholder { color: #444; font-weight: 300; }

  #sendBtn {
    background-color: #F5A623;
    border: none;
    cursor: pointer;
    padding: 0 1.2rem;
    min-height: 54px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background-color 0.2s;
    flex-shrink: 0;
  }

  #sendBtn:hover { background-color: #c4811a; }
  #sendBtn:disabled { opacity: 0.5; cursor: not-allowed; }

  #sendBtn svg { width: 20px; height: 20px; }
</style>