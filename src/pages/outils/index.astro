---
import Layout from '../../layouts/Layout.astro';

const outils = [
  {
    slug: "/outils/calculateur-stock-eau",
    titre: "Calculateur de stock d'eau",
    description: "Combien de litres stocker selon le nombre de personnes, la durée visée et les usages. Le calcul qu'on aurait dû faire avant.",
    tags: ["eau", "stock", "calcul", "kit-72h"],
    temps: "2 min"
  }
]
---

<Layout title="Les Outils — Survivalix" description="Calculateurs et outils interactifs pour préparer votre autonomie. Concrets, rapides, sans bullshit.">

  <div class="manuel-header">
    <div class="manuel-header-label">// SECTION 04 //</div>
    <h1>Les Outils</h1>
    <p class="manuel-header-desc">Calculateurs et outils interactifs pour préparer ton autonomie. Concrets, rapides, sans bullshit.</p>
    <div class="manuel-stats">
      <span><strong>{outils.length}</strong> outil{outils.length > 1 ? 's' : ''} disponible{outils.length > 1 ? 's' : ''}</span>
    </div>
  </div>

  <div class="manuel-grid">
    {outils.map((outil, index) => (
      <a href={outil.slug} class="article-card article-card-link">
        <div class="card-image">
          <svg viewBox="0 0 400 200" xmlns="http://www.w3.org/2000/svg" style="width:100%;height:100%;display:block;position:absolute;top:0;left:0;">
            <defs>
              <pattern id={`sl-${index}`} width="1" height="3" patternUnits="userSpaceOnUse">
                <rect width="1" height="1" fill="#F5A623" opacity="0.04"/>
              </pattern>
              <pattern id={`gr-${index}`} width="20" height="20" patternUnits="userSpaceOnUse">
                <path d="M 20 0 L 0 0 0 20" fill="none" stroke="#F5A623" stroke-width="0.3" opacity="0.12"/>
              </pattern>
            </defs>
            <rect width="400" height="200" fill="#0d0d0d"/>
            <rect width="400" height="200" fill={`url(#gr-${index})`}/>
            <rect width="400" height="200" fill={`url(#sl-${index})`}/>
            <line x1="200" y1="0" x2="200" y2="200" stroke="#F5A623" stroke-width="0.5" opacity="0.2" stroke-dasharray="4 4"/>
            <line x1="0" y1="100" x2="400" y2="100" stroke="#F5A623" stroke-width="0.5" opacity="0.2" stroke-dasharray="4 4"/>
            <line x1="0" y1="0" x2="400" y2="200" stroke="#F5A623" stroke-width="0.3" opacity="0.07"/>
            <line x1="400" y1="0" x2="0" y2="200" stroke="#F5A623" stroke-width="0.3" opacity="0.07"/>
            <circle cx="200" cy="100" r="88" fill="none" stroke="#F5A623" stroke-width="1.2" opacity="0.45"/>
            <circle cx="200" cy="100" r="68" fill="none" stroke="#F5A623" stroke-width="0.8" opacity="0.3"/>
            <circle cx="200" cy="100" r="48" fill="none" stroke="#F5A623" stroke-width="1.5" opacity="0.55"/>
            <circle cx="200" cy="100" r="30" fill="none" stroke="#F5A623" stroke-width="0.8" opacity="0.35"/>
            <circle cx="200" cy="100" r="14" fill="#F5A623" opacity="0.12"/>
            <circle cx="200" cy="100" r="5" fill="#F5A623" opacity="0.65"/>
            <circle cx="200" cy="100" r="2" fill="#0d0d0d"/>
            <line x1="200" y1="12" x2="200" y2="22" stroke="#F5A623" stroke-width="1" opacity="0.55"/>
            <line x1="200" y1="178" x2="200" y2="188" stroke="#F5A623" stroke-width="1" opacity="0.55"/>
            <line x1="112" y1="100" x2="122" y2="100" stroke="#F5A623" stroke-width="1" opacity="0.55"/>
            <line x1="278" y1="100" x2="288" y2="100" stroke="#F5A623" stroke-width="1" opacity="0.55"/>
            <path d="M200 76 C200 76 185 90 185 100 C185 109 192 114 200 114 C208 114 215 109 215 100 C215 90 200 76 200 76Z" fill="#F5A623" opacity="0.12" stroke="#F5A623" stroke-width="1.4"/>
            <path d="M192 106 C192 111 196 113 200 113" stroke="#F5A623" stroke-width="1" fill="none" opacity="0.35" stroke-linecap="round"/>
            <circle cx="38" cy="38" r="24" fill="none" stroke="#F5A623" stroke-width="1" opacity="0.35"/>
            <circle cx="38" cy="38" r="16" fill="none" stroke="#F5A623" stroke-width="0.6" opacity="0.25"/>
            <line x1="38" y1="14" x2="38" y2="22" stroke="#F5A623" stroke-width="1" opacity="0.45"/>
            <line x1="14" y1="38" x2="22" y2="38" stroke="#F5A623" stroke-width="1" opacity="0.45"/>
            <line x1="62" y1="38" x2="54" y2="38" stroke="#F5A623" stroke-width="1" opacity="0.45"/>
            <line x1="38" y1="62" x2="38" y2="54" stroke="#F5A623" stroke-width="1" opacity="0.45"/>
            <line x1="38" y1="38" x2="50" y2="24" stroke="#F5A623" stroke-width="1.5" stroke-linecap="round" opacity="0.75"/>
            <circle cx="38" cy="38" r="3" fill="#F5A623" opacity="0.65"/>
            <circle cx="362" cy="38" r="9" fill="none" stroke="#F5A623" stroke-width="1" opacity="0.45"/>
            <ellipse cx="362" cy="38" rx="22" ry="9" fill="none" stroke="#F5A623" stroke-width="0.8" opacity="0.3"/>
            <ellipse cx="362" cy="38" rx="9" ry="22" fill="none" stroke="#F5A623" stroke-width="0.8" opacity="0.3"/>
            <ellipse cx="362" cy="38" rx="18" ry="7" fill="none" stroke="#F5A623" stroke-width="0.5" opacity="0.18" transform="rotate(60,362,38)"/>
            <circle cx="362" cy="38" r="3.5" fill="#F5A623" opacity="0.65"/>
            <circle cx="38" cy="162" r="9" fill="none" stroke="#F5A623" stroke-width="1" opacity="0.45"/>
            <ellipse cx="38" cy="162" rx="22" ry="9" fill="none" stroke="#F5A623" stroke-width="0.8" opacity="0.3"/>
            <ellipse cx="38" cy="162" rx="9" ry="22" fill="none" stroke="#F5A623" stroke-width="0.8" opacity="0.3"/>
            <circle cx="38" cy="162" r="3.5" fill="#F5A623" opacity="0.65"/>
            <circle cx="362" cy="162" r="24" fill="none" stroke="#F5A623" stroke-width="1" opacity="0.35"/>
            <circle cx="362" cy="162" r="16" fill="none" stroke="#F5A623" stroke-width="0.6" opacity="0.25"/>
            <line x1="362" y1="138" x2="362" y2="146" stroke="#F5A623" stroke-width="1" opacity="0.45"/>
            <line x1="338" y1="162" x2="346" y2="162" stroke="#F5A623" stroke-width="1" opacity="0.45"/>
            <line x1="386" y1="162" x2="378" y2="162" stroke="#F5A623" stroke-width="1" opacity="0.45"/>
            <line x1="362" y1="186" x2="362" y2="178" stroke="#F5A623" stroke-width="1" opacity="0.45"/>
            <line x1="362" y1="162" x2="374" y2="150" stroke="#F5A623" stroke-width="1.5" stroke-linecap="round" opacity="0.75"/>
            <circle cx="362" cy="162" r="3" fill="#F5A623" opacity="0.65"/>
            <rect x="2" y="2" width="396" height="196" fill="none" stroke="#F5A623" stroke-width="0.8" opacity="0.18"/>
            <line x1="100" y1="2" x2="100" y2="7" stroke="#F5A623" stroke-width="1" opacity="0.35"/>
            <line x1="200" y1="2" x2="200" y2="7" stroke="#F5A623" stroke-width="1" opacity="0.35"/>
            <line x1="300" y1="2" x2="300" y2="7" stroke="#F5A623" stroke-width="1" opacity="0.35"/>
            <line x1="100" y1="198" x2="100" y2="193" stroke="#F5A623" stroke-width="1" opacity="0.35"/>
            <line x1="300" y1="198" x2="300" y2="193" stroke="#F5A623" stroke-width="1" opacity="0.35"/>
            <text x="200" y="19" font-family="Oswald,sans-serif" font-size="6" fill="#F5A623" text-anchor="middle" opacity="0.4">90</text>
            <text x="200" y="184" font-family="Oswald,sans-serif" font-size="6" fill="#F5A623" text-anchor="middle" opacity="0.4">270</text>
            <text x="106" y="103" font-family="Oswald,sans-serif" font-size="6" fill="#F5A623" text-anchor="middle" opacity="0.4">180</text>
            <text x="294" y="103" font-family="Oswald,sans-serif" font-size="6" fill="#F5A623" text-anchor="middle" opacity="0.4">0</text>
          </svg>
        </div>
        <div class="card-body">
          <div class="card-top">
            <span class="card-num">0{index + 1}</span>
            <span class="card-temps">~{outil.temps}</span>
          </div>
          <div class="card-tags">
            {outil.tags.map((tag: string) => (
              <span class="card-tag">#{tag}</span>
            ))}
          </div>
          <h2 class="card-titre">{outil.titre}</h2>
          <p class="card-desc">{outil.description}</p>
          <div class="card-footer">
            <span class="card-lien">
              Utiliser l'outil
              <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <line x1="4" y1="12" x2="20" y2="12" stroke="#F5A623" stroke-width="1.5" stroke-linecap="round"/>
                <polyline points="14,6 20,12 14,18" stroke="#F5A623" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </span>
          </div>
        </div>
      </a>
    ))}
  </div>

</Layout>

<style>
  .manuel-header {
    text-align: center;
    padding: 3rem 0 2rem;
    border-bottom: 1px solid #1a1a1a;
    margin-bottom: 3rem;
  }
  .manuel-header-label {
    font-family: 'Oswald', sans-serif;
    font-size: 0.75rem;
    color: #6B7C45;
    letter-spacing: 4px;
    margin-bottom: 1rem;
  }
  .manuel-header h1 {
    font-family: 'Special Elite', cursive;
    font-size: clamp(2rem, 6vw, 3.5rem);
    color: #F5A623;
    letter-spacing: 4px;
    margin-bottom: 1rem;
  }
  .manuel-header-desc {
    font-family: 'Oswald', sans-serif;
    font-size: 1rem;
    color: #F5E6C8;
    opacity: 0.7;
    font-weight: 300;
    margin-bottom: 1.5rem;
    max-width: 500px;
    margin-left: auto;
    margin-right: auto;
  }
  .manuel-stats {
    font-family: 'Oswald', sans-serif;
    font-size: 0.8rem;
    color: #666;
    letter-spacing: 2px;
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 1rem;
  }
  .manuel-stats strong { color: #F5A623; }
  .manuel-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }
  @media (min-width: 600px) {
    .manuel-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (min-width: 900px) {
    .manuel-grid { grid-template-columns: repeat(3, 1fr); }
  }
  .article-card {
    background-color: #0d0d0d;
    border: 1px solid #222;
    border-top: 3px solid #F5A623;
    display: flex;
    flex-direction: column;
    transition: border-color 0.2s, transform 0.2s;
    position: relative;
    text-decoration: none;
  }
  .article-card-link:hover {
    border-color: #333;
    transform: translateY(-3px);
  }
  .card-image {
    width: 100%;
    height: 160px;
    overflow: hidden;
    position: relative;
    background-color: #0d0d0d;
  }
  .card-body {
    padding: 1.2rem;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    flex: 1;
  }
  .card-top {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .card-num {
    font-family: 'Special Elite', cursive;
    font-size: 1.8rem;
    color: #2a2a2a;
    line-height: 1;
  }
  .card-temps {
    font-family: 'Oswald', sans-serif;
    font-size: 0.7rem;
    color: #555;
    letter-spacing: 1px;
    border: 1px solid #222;
    padding: 0.2rem 0.6rem;
  }
  .card-tags {
    display: flex;
    gap: 0.4rem;
    flex-wrap: wrap;
  }
  .card-tag {
    font-family: 'Oswald', sans-serif;
    font-size: 0.65rem;
    color: #6B7C45;
    letter-spacing: 1px;
    border: 1px solid #6B7C45;
    padding: 0.1rem 0.5rem;
  }
  .card-titre {
    font-family: 'Special Elite', cursive;
    font-size: clamp(0.9rem, 2vw, 1rem);
    color: #F5E6C8;
    line-height: 1.3;
    letter-spacing: 0.5px;
    border: none !important;
    padding: 0 !important;
    margin: 0 !important;
  }
  .card-desc {
    font-family: 'Oswald', sans-serif;
    font-size: 0.82rem;
    color: #F5E6C8;
    opacity: 0.55;
    line-height: 1.6;
    font-weight: 300;
    flex: 1;
    margin: 0 !important;
  }
  .card-footer {
    margin-top: 0.5rem;
    padding-top: 0.8rem;
    border-top: 1px solid #1a1a1a;
  }
  .card-lien {
    font-family: 'Oswald', sans-serif;
    font-size: 0.8rem;
    font-weight: 700;
    color: #F5A623;
    letter-spacing: 1px;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    transition: gap 0.2s;
  }
  .card-lien svg { width: 14px; height: 14px; flex-shrink: 0; }
  .article-card-link:hover .card-lien { gap: 0.8rem; }
</style>