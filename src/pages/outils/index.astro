---
import Layout from '../../layouts/Layout.astro';

const outils = [
  {
    slug: "/outils/calculateur-stock-eau",
    titre: "Calculateur de stock d'eau",
    description: "Combien de litres stocker selon le nombre de personnes, la durée visée et les usages. Le calcul qu'on aurait dû faire avant.",
    tags: ["eau", "stock", "calcul", "kit-72h"],
    icone: "eau",
    temps: "2 min"
  }
]
---

<Layout title="Les Outils — Survivalix" description="Calculateurs et outils interactifs pour préparer votre autonomie. Concrets, rapides, sans bullshit.">

  <div class="manuel-header">
    <div class="manuel-header-label">// SECTION 04 //</div>
    <h1>Les Outils</h1>
    <p class="manuel-header-desc">Calculateurs et outils interactifs pour préparer ton autonomie. Concrets, rapides, sans bullshit.</p>
    <div class="manuel-stats">
      <span><strong>{outils.length}</strong> outil{outils.length > 1 ? 's' : ''} disponible{outils.length > 1 ? 's' : ''}</span>
    </div>
  </div>

  <div class="manuel-grid">
    {outils.map((outil, index) => (
      <a href={outil.slug} class="article-card article-card-link">
        <div class="card-image card-image-placeholder">
          <svg viewBox="0 0 400 200" preserveAspectRatio="xMidYMid slice" xmlns="http://www.w3.org/2000/svg" style="width:100%;height:100%;position:absolute;top:0;left:0;">
            <defs>
              <pattern id={`dots-${index}`} width="20" height="20" patternUnits="userSpaceOnUse">
                <circle cx="10" cy="10" r="0.8" fill="#F5A623" opacity="0.12"/>
              </pattern>
            </defs>
            <!-- Fond noir + texture halftone -->
            <rect width="400" height="200" fill="#0d0d0d"/>
            <rect width="400" height="200" fill={`url(#dots-${index})`}/>

            <!-- Bouteilles d'eau (gauche) -->
            <!-- Bouteille 1 -->
            <rect x="42" y="60" width="28" height="70" rx="4" fill="#0d0d0d" stroke="#F5A623" stroke-width="1.5"/>
            <rect x="48" y="52" width="16" height="12" rx="2" fill="#0d0d0d" stroke="#F5A623" stroke-width="1.5"/>
            <rect x="51" y="44" width="10" height="10" rx="1" fill="#F5A623" opacity="0.8"/>
            <rect x="42" y="85" width="28" height="3" fill="#6B7C45" opacity="0.6"/>
            <rect x="42" y="92" width="28" height="3" fill="#6B7C45" opacity="0.4"/>
            <path d="M50 65 Q56 68 62 65" stroke="#F5A623" stroke-width="0.8" fill="none" opacity="0.5"/>

            <!-- Bouteille 2 -->
            <rect x="82" y="72" width="22" height="58" rx="3" fill="#0d0d0d" stroke="#F5A623" stroke-width="1.5"/>
            <rect x="87" y="64" width="12" height="10" rx="2" fill="#0d0d0d" stroke="#F5A623" stroke-width="1.5"/>
            <rect x="89" y="57" width="8" height="8" rx="1" fill="#F5A623" opacity="0.8"/>
            <rect x="82" y="93" width="22" height="2.5" fill="#6B7C45" opacity="0.5"/>

            <!-- Bouteille 3 -->
            <rect x="116" y="55" width="32" height="75" rx="5" fill="#0d0d0d" stroke="#F5A623" stroke-width="1.5"/>
            <rect x="122" y="46" width="20" height="12" rx="2" fill="#0d0d0d" stroke="#F5A623" stroke-width="1.5"/>
            <rect x="125" y="38" width="14" height="10" rx="2" fill="#F5A623" opacity="0.8"/>
            <rect x="116" y="80" width="32" height="3" fill="#6B7C45" opacity="0.6"/>
            <rect x="116" y="88" width="32" height="3" fill="#6B7C45" opacity="0.4"/>
            <path d="M124 63 Q132 67 140 63" stroke="#F5A623" stroke-width="0.8" fill="none" opacity="0.5"/>

            <!-- Silhouettes de personnes (droite) -->
            <!-- Personne 1 -->
            <circle cx="240" cy="68" r="10" fill="#0d0d0d" stroke="#F5A623" stroke-width="1.5"/>
            <path d="M232 82 Q240 78 248 82 L250 130 L230 130 Z" fill="#0d0d0d" stroke="#F5A623" stroke-width="1.5"/>
            <line x1="230" y1="90" x2="222" y2="112" stroke="#F5A623" stroke-width="1.5" stroke-linecap="round"/>
            <line x1="250" y1="90" x2="258" y2="112" stroke="#F5A623" stroke-width="1.5" stroke-linecap="round"/>

            <!-- Personne 2 -->
            <circle cx="280" cy="72" r="8" fill="#0d0d0d" stroke="#F5A623" stroke-width="1.5"/>
            <path d="M273 84 Q280 80 287 84 L289 130 L271 130 Z" fill="#0d0d0d" stroke="#F5A623" stroke-width="1.5"/>

            <!-- Personne 3 (enfant, plus petite) -->
            <circle cx="312" cy="82" r="7" fill="#0d0d0d" stroke="#6B7C45" stroke-width="1.5"/>
            <path d="M306 93 Q312 90 318 93 L320 130 L304 130 Z" fill="#0d0d0d" stroke="#6B7C45" stroke-width="1.5"/>

            <!-- Flèche centrale séparatrice -->
            <line x1="168" y1="40" x2="168" y2="165" stroke="#F5A623" stroke-width="0.8" stroke-dasharray="4 3" opacity="0.4"/>
            <polygon points="168,38 163,46 173,46" fill="#F5A623" opacity="0.5"/>

            <!-- Signe "+" -->
            <text x="190" y="108" font-family="Oswald,sans-serif" font-size="28" font-weight="700" fill="#F5A623" opacity="0.15" text-anchor="middle">=</text>
            <text x="195" y="105" font-family="Oswald,sans-serif" font-size="22" font-weight="700" fill="#F5A623" opacity="0.6" text-anchor="middle">?L</text>

            <!-- Bandeau label -->
            <rect x="0" y="162" width="400" height="28" fill="#F5A623" opacity="0.9"/>
            <text x="16" y="181" font-family="Oswald,sans-serif" font-size="10" font-weight="700" fill="#0d0d0d" letter-spacing="2">// CALCULATEUR STOCK D'EAU //</text>

            <!-- Coins vintage -->
            <path d="M8 8 L8 22 M8 8 L22 8" stroke="#F5A623" stroke-width="1.5" fill="none" opacity="0.4"/>
            <path d="M392 8 L392 22 M392 8 L378 8" stroke="#F5A623" stroke-width="1.5" fill="none" opacity="0.4"/>
          </svg>
        </div>
        <div class="card-body">
          <div class="card-top">
            <span class="card-num">0{index + 1}</span>
            <span class="card-temps">~{outil.temps}</span>
          </div>
          <div class="card-tags">
            {outil.tags.map((tag: string) => (
              <span class="card-tag">#{tag}</span>
            ))}
          </div>
          <h2 class="card-titre">{outil.titre}</h2>
          <p class="card-desc">{outil.description}</p>
          <div class="card-footer">
            <span class="card-lien">
              Utiliser l'outil
              <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <line x1="4" y1="12" x2="20" y2="12" stroke="#F5A623" stroke-width="1.5" stroke-linecap="round"/>
                <polyline points="14,6 20,12 14,18" stroke="#F5A623" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </span>
          </div>
        </div>
      </a>
    ))}
  </div>

</Layout>

<style>
  .manuel-header {
    text-align: center;
    padding: 3rem 0 2rem;
    border-bottom: 1px solid #1a1a1a;
    margin-bottom: 3rem;
  }

  .manuel-header-label {
    font-family: 'Oswald', sans-serif;
    font-size: 0.75rem;
    color: #6B7C45;
    letter-spacing: 4px;
    margin-bottom: 1rem;
  }

  .manuel-header h1 {
    font-family: 'Special Elite', cursive;
    font-size: clamp(2rem, 6vw, 3.5rem);
    color: #F5A623;
    letter-spacing: 4px;
    margin-bottom: 1rem;
  }

  .manuel-header-desc {
    font-family: 'Oswald', sans-serif;
    font-size: 1rem;
    color: #F5E6C8;
    opacity: 0.7;
    font-weight: 300;
    margin-bottom: 1.5rem;
    max-width: 500px;
    margin-left: auto;
    margin-right: auto;
  }

  .manuel-stats {
    font-family: 'Oswald', sans-serif;
    font-size: 0.8rem;
    color: #666;
    letter-spacing: 2px;
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 1rem;
  }

  .manuel-stats strong { color: #F5A623; }

  .manuel-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }

  @media (min-width: 600px) {
    .manuel-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (min-width: 900px) {
    .manuel-grid { grid-template-columns: repeat(3, 1fr); }
  }

  .article-card {
    background-color: #0d0d0d;
    border: 1px solid #222;
    border-top: 3px solid #F5A623;
    display: flex;
    flex-direction: column;
    transition: border-color 0.2s, transform 0.2s;
    position: relative;
    text-decoration: none;
  }

  .article-card-link:hover {
    border-color: #333;
    transform: translateY(-3px);
  }

  .card-image {
    width: 100%;
    height: 160px;
    overflow: hidden;
    position: relative;
    background-color: #0d0d0d;
  }

  .card-image-placeholder { background-color: #080808; }

  .card-body {
    padding: 1.2rem;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    flex: 1;
  }

  .card-top {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .card-num {
    font-family: 'Special Elite', cursive;
    font-size: 1.8rem;
    color: #2a2a2a;
    line-height: 1;
  }

  .card-temps {
    font-family: 'Oswald', sans-serif;
    font-size: 0.7rem;
    color: #555;
    letter-spacing: 1px;
    border: 1px solid #222;
    padding: 0.2rem 0.6rem;
  }

  .card-tags {
    display: flex;
    gap: 0.4rem;
    flex-wrap: wrap;
  }

  .card-tag {
    font-family: 'Oswald', sans-serif;
    font-size: 0.65rem;
    color: #6B7C45;
    letter-spacing: 1px;
    border: 1px solid #6B7C45;
    padding: 0.1rem 0.5rem;
  }

  .card-titre {
    font-family: 'Special Elite', cursive;
    font-size: clamp(0.9rem, 2vw, 1rem);
    color: #F5E6C8;
    line-height: 1.3;
    letter-spacing: 0.5px;
    border: none !important;
    padding: 0 !important;
    margin: 0 !important;
  }

  .card-desc {
    font-family: 'Oswald', sans-serif;
    font-size: 0.82rem;
    color: #F5E6C8;
    opacity: 0.55;
    line-height: 1.6;
    font-weight: 300;
    flex: 1;
    margin: 0 !important;
  }

  .card-footer {
    margin-top: 0.5rem;
    padding-top: 0.8rem;
    border-top: 1px solid #1a1a1a;
  }

  .card-lien {
    font-family: 'Oswald', sans-serif;
    font-size: 0.8rem;
    font-weight: 700;
    color: #F5A623;
    letter-spacing: 1px;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    transition: gap 0.2s;
  }

  .card-lien svg { width: 14px; height: 14px; flex-shrink: 0; }
  .article-card-link:hover .card-lien { gap: 0.8rem; }
</style>