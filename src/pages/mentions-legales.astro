<style>
  .legal-header {
    text-align: center;
    padding: 3rem 0 2rem;
    border-bottom: 1px solid #1a1a1a;
    margin-bottom: 3rem;
  }

  .legal-label {
    font-family: 'Oswald', sans-serif;
    font-size: 0.75rem;
    color: #6B7C45;
    letter-spacing: 4px;
    margin-bottom: 1rem;
  }

  .legal-header h1 {
    font-family: 'Special Elite', cursive;
    font-size: clamp(2rem, 5vw, 3rem);
    color: #F5A623;
    letter-spacing: 3px;
  }

  .legal-content {
    max-width: 760px;
    margin: 0 auto;
    padding: 0 1.5rem 4rem;
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
  }

  .legal-section h2 {
    font-family: 'Oswald', sans-serif;
    font-size: 0.85rem;
    font-weight: 700;
    color: #F5A623;
    letter-spacing: 3px;
    text-transform: uppercase;
    margin-bottom: 1rem;
    padding-bottom: 0.4rem;
    border-bottom: 1px solid #1a1a1a;
  }

  .legal-section p {
    font-family: 'Oswald', sans-serif;
    font-size: 0.92rem;
    color: #F5E6C8;
    opacity: 0.8;
    font-weight: 300;
    line-height: 1.8;
    margin-bottom: 0.8rem;
  }

  .legal-section p:last-child { margin-bottom: 0; }

  .legal-section strong { color: #ffffff; font-weight: 700; }

  .legal-section a {
    color: #F5A623;
    text-decoration: none;
  }

  .legal-section a:hover { opacity: 0.7; }

  .legal-date {
    font-family: 'Oswald', sans-serif;
    font-size: 0.75rem;
    color: #444;
    letter-spacing: 1px;
    text-align: right;
    margin-top: 1rem;
  }
</style>