---
import Layout from '../layouts/Layout.astro';
---

<Layout 
  title="Survivalix : Le Site de Survie pour les Gens Normaux"
  description="Guides, recettes, calculateurs et IA de survie pour urbains curieux. Kit 72h, autonomie, prepping sans clichés ni bullshit. Testé, sourcé, décalé."
>

  <!-- BLOC 1 — HERO -->
  <section class="hero">
    <div class="hero-label">// TRANSMISSION EN COURS //</div>
    <h1 class="hero-titre">La survie,<br/>c'est pas que pour les fous.</h1>
    <p class="hero-accroche">
      Guides pratiques, recettes qui ont du goût, outils interactifs 
      et humour second degré. Tout ce qu'il faut savoir pour être prêt 
      sans devenir parano.
    </p>
    <div class="hero-ctas">
      <a href="/commencer-ici" class="btn-primary">Par où commencer ?</a>
      <a href="/survivant" class="btn-secondary">Quel Survivant es-tu ?</a>
    </div>
    <div class="hero-stats">
      <div class="stat">
        <span class="stat-num">72h</span>
        <span class="stat-label">d'autonomie minimum</span>
      </div>
      <div class="stat-sep">//</div>
      <div class="stat">
        <span class="stat-num">3L</span>
        <span class="stat-label">d'eau par jour par personne</span>
      </div>
      <div class="stat-sep">//</div>
      <div class="stat">
        <span class="stat-num">0€</span>
        <span class="stat-label">pour commencer à se préparer</span>
      </div>
    </div>
  </section>

  <!-- BLOC 2 — RASSURANT -->
  <section class="reassurance">
    <div class="reassurance-inner">
      <div class="reassurance-label">// C'EST QUOI CE SITE ? //</div>
      <p class="reassurance-texte">
        Survivalix c'est pour toi si tu as déjà pensé <em>"et si ça merde vraiment ?"</em> 
        sans savoir quoi faire. Pas de théories complotistes, pas d'arsenal militaire, 
        pas de sermon. Juste des infos utiles, présentées sans se prendre au sérieux.
      </p>
      <div class="reassurance-points">
        <div class="point">
          <span class="point-icon">✓</span>
          <span>Tu habites en ville ? On a tout prévu pour toi.</span>
        </div>
        <div class="point">
          <span class="point-icon">✓</span>
          <span>Tu as 20€ à investir ? C'est largement suffisant pour commencer.</span>
        </div>
        <div class="point">
          <span class="point-icon">✓</span>
          <span>Tu trouves le sujet fascinant mais tu ne te définirais jamais comme survivaliste ? Tu es exactement au bon endroit.</span>
        </div>
        <div class="point">
          <span class="point-icon">✓</span>
          <span>Tu veux manger correctement même en cas de crise ? On a les recettes.</span>
        </div>
      </div>
    </div>
  </section>

  <!-- BLOC 3 — PAR OÙ COMMENCER -->
  <section class="demarrer">
    <div class="section-label">// PROTOCOLE DE DÉMARRAGE //</div>
    <h2>Tu débarques ici ?</h2>
    <p>Trois missions prioritaires pour le citoyen qui commence.</p>
    <div class="missions">
      <div class="mission">
        <div class="mission-num">01</div>
        <h3>Découvre ton profil</h3>
        <p>Fais le quiz et reçois ta carte Survivant personnalisée à partager.</p>
        <a href="/survivant" class="mission-lien">Faire le quiz →</a>
      </div>
      <div class="mission">
        <div class="mission-num">02</div>
        <h3>Monte ton kit 72h</h3>
        <p>Le strict minimum pour tenir 3 jours sans rien. Simple, sans bullshit.</p>
        <a href="/manuel/kit-urgence-72h" class="mission-lien">Voir le guide →</a>
      </div>
      <div class="mission">
        <div class="mission-num">03</div>
        <h3>Pose tes questions</h3>
        <p>L'assistant IA du Bunker répond à tout, sans jargon, avec humour.</p>
        <a href="/bunker" class="mission-lien">Accéder au Bunker →</a>
      </div>
    </div>
  </section>

  <!-- BLOC 4 — RUBRIQUES -->
  <section class="rubriques">
    <div class="section-label">// SECTEURS D'ACTIVITÉ //</div>
    <h2>Explore le site</h2>
    <div class="rubriques-grid">

      <a href="/manuel" class="rubrique-card">
        <div class="rubrique-icon">
          <svg viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg">
            <rect x="14" y="6" width="36" height="52" rx="2" stroke="#F5A623" stroke-width="1.5"/>
            <rect x="14" y="6" width="8" height="52" stroke="#F5A623" stroke-width="1.5" fill="none"/>
            <line x1="28" y1="18" x2="44" y2="18" stroke="#F5A623" stroke-width="1.5" stroke-linecap="round"/>
            <line x1="28" y1="26" x2="44" y2="26" stroke="#F5A623" stroke-width="1.5" stroke-linecap="round"/>
            <line x1="28" y1="34" x2="44" y2="34" stroke="#F5A623" stroke-width="1.5" stroke-linecap="round"/>
            <line x1="28" y1="42" x2="38" y2="42" stroke="#F5A623" stroke-width="1.5" stroke-linecap="round"/>
            <circle cx="18" cy="20" r="1.5" fill="#F5A623"/>
            <circle cx="18" cy="32" r="1.5" fill="#F5A623"/>
            <circle cx="18" cy="44" r="1.5" fill="#F5A623"/>
          </svg>
        </div>
        <h3>Le Manuel</h3>
        <p>Guides de fond, checklists, méthodes éprouvées.</p>
      </a>

      <a href="/cantine" class="rubrique-card">
        <div class="rubrique-icon">
          <svg viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M12 28 C12 16 20 10 32 10 C44 10 52 16 52 28 L50 48 C50 51 47 54 44 54 L20 54 C17 54 14 51 14 48 Z" stroke="#F5A623" stroke-width="1.5"/>
            <ellipse cx="32" cy="28" rx="20" ry="6" stroke="#F5A623" stroke-width="1.5"/>
            <line x1="22" y1="6" x2="22" y2="12" stroke="#F5A623" stroke-width="1.5" stroke-linecap="round"/>
            <line x1="32" y1="4" x2="32" y2="10" stroke="#F5A623" stroke-width="1.5" stroke-linecap="round"/>
            <line x1="42" y1="6" x2="42" y2="12" stroke="#F5A623" stroke-width="1.5" stroke-linecap="round"/>
            <path d="M20 38 Q32 34 44 38" stroke="#F5A623" stroke-width="1.5" fill="none" stroke-linecap="round"/>
          </svg>
        </div>
        <h3>La Cantine</h3>
        <p>Recettes de survie qui ont vraiment du goût.</p>
      </a>

      <a href="/bunker" class="rubrique-card rubrique-card-special">
        <div class="rubrique-icon">
          <svg viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg">
            <rect x="12" y="20" width="40" height="32" rx="2" stroke="#F5A623" stroke-width="1.5"/>
            <rect x="20" y="28" width="8" height="6" rx="1" stroke="#F5A623" stroke-width="1.5"/>
            <rect x="36" y="28" width="8" height="6" rx="1" stroke="#F5A623" stroke-width="1.5"/>
            <line x1="24" y1="42" x2="40" y2="42" stroke="#F5A623" stroke-width="1.5" stroke-linecap="round"/>
            <line x1="32" y1="12" x2="32" y2="20" stroke="#F5A623" stroke-width="1.5"/>
            <circle cx="32" cy="10" r="3" stroke="#F5A623" stroke-width="1.5"/>
            <line x1="16" y1="36" x2="8" y2="36" stroke="#F5A623" stroke-width="1.5" stroke-linecap="round"/>
            <line x1="48" y1="36" x2="56" y2="36" stroke="#F5A623" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
        </div>
        <h3>Le Bunker</h3>
        <p>Assistant IA — pose tes questions, reçois des réponses personnalisées.</p>
        <span class="rubrique-badge">IA</span>
      </a>

      <a href="/atelier" class="rubrique-card">
        <div class="rubrique-icon">
          <svg viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M42 8 C48 8 54 14 52 20 C51 24 48 26 48 26 L18 56 L10 48 L40 18 C40 18 40 14 42 8 Z" stroke="#F5A623" stroke-width="1.5" stroke-linejoin="round"/>
            <circle cx="14" cy="52" r="4" stroke="#F5A623" stroke-width="1.5"/>
            <line x1="46" y1="12" x2="52" y2="18" stroke="#F5A623" stroke-width="2" stroke-linecap="round"/>
          </svg>
        </div>
        <h3>L'Atelier</h3>
        <p>DIY, autonomie, faire soi-même avec ce qu'on a.</p>
      </a>

      <a href="/radar" class="rubrique-card">
        <div class="rubrique-icon">
          <svg viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg">
            <circle cx="32" cy="32" r="22" stroke="#F5A623" stroke-width="1.5" fill="none"/>
            <circle cx="32" cy="32" r="14" stroke="#F5A623" stroke-width="1.5" fill="none" stroke-dasharray="3 3"/>
            <circle cx="32" cy="32" r="6" stroke="#F5A623" stroke-width="1.5"/>
            <circle cx="32" cy="32" r="2" fill="#F5A623"/>
            <line x1="32" y1="10" x2="32" y2="32" stroke="#F5A623" stroke-width="1.5" stroke-linecap="round"/>
            <line x1="32" y1="32" x2="48" y2="22" stroke="#F5A623" stroke-width="1.5" stroke-linecap="round" opacity="0.5"/>
            <circle cx="48" cy="20" r="3" stroke="#F5A623" stroke-width="1.5"/>
            <line x1="32" y1="54" x2="32" y2="60" stroke="#F5A623" stroke-width="1.5"/>
            <line x1="22" y1="60" x2="42" y2="60" stroke="#F5A623" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
        </div>
        <h3>Le Radar</h3>
        <p>Veille, signaux faibles, actu qui compte.</p>
      </a>

      <a href="/outils" class="rubrique-card">
        <div class="rubrique-icon">
          <svg viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg">
            <rect x="6" y="6" width="16" height="16" stroke="#F5A623" stroke-width="1.5" fill="none"/>
            <rect x="26" y="6" width="16" height="16" stroke="#F5A623" stroke-width="1.5" fill="none"/>
            <rect x="6" y="26" width="16" height="16" stroke="#F5A623" stroke-width="1.5" fill="none"/>
            <rect x="26" y="26" width="16" height="16" stroke="#F5A623" stroke-width="1.5" fill="none"/>
            <line x1="10" y1="14" x2="18" y2="14" stroke="#F5A623" stroke-width="1.5" stroke-linecap="round"/>
            <line x1="30" y1="11" x2="38" y2="11" stroke="#F5A623" stroke-width="1.5" stroke-linecap="round"/>
            <line x1="30" y1="16" x2="34" y2="16" stroke="#F5A623" stroke-width="1.5" stroke-linecap="round"/>
            <line x1="10" y1="34" x2="18" y2="34" stroke="#F5A623" stroke-width="1.5" stroke-linecap="round"/>
            <circle cx="46" cy="46" r="10" stroke="#F5A623" stroke-width="1.5" fill="none"/>
            <line x1="53" y1="53" x2="58" y2="58" stroke="#F5A623" stroke-width="2" stroke-linecap="round"/>
          </svg>
        </div>
        <h3>Les Outils</h3>
        <p>Calculateurs, checklists interactives, générateurs.</p>
      </a>

    </div>
  </section>

  <!-- BLOC 5 — QUIZ CTA -->
  <section class="quiz-cta">
    <div class="quiz-cta-inner">
      <div class="section-label">// IDENTIFICATION DU CITOYEN //</div>
      <h2>Quel type de Survivant es-tu ?</h2>
      <p>
        Le Bâtisseur ? Le Nourricier ? L'Explorateur ? Le Technicien ? 
        Fais le quiz en 2 minutes et télécharge ta carte collector personnalisée.
      </p>
      <a href="/survivant" class="btn-primary">Découvrir mon profil</a>
    </div>
  </section>

</Layout>

<style>
  /* HERO */
  .hero {
    text-align: center;
    padding: 3rem 0 4rem;
    border-bottom: 1px solid #222;
  }

  .hero-label {
    font-family: 'Oswald', sans-serif;
    font-size: 0.75rem;
    color: #6B7C45;
    letter-spacing: 4px;
    margin-bottom: 1.5rem;
  }

  .hero-titre {
    font-family: 'Special Elite', cursive;
    font-size: clamp(1.8rem, 6vw, 3.2rem);
    color: #F5A623;
    line-height: 1.1;
    margin-bottom: 1.5rem;
    letter-spacing: 2px;
  }

  .hero-accroche {
    font-size: clamp(1rem, 2.5vw, 1.2rem);
    color: #ffffff;
    max-width: 700px;
    margin: 0 auto 2.5rem;
    opacity: 0.85;
    line-height: 1.8;
    font-weight: 300;
  }

  .hero-ctas {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
    margin-bottom: 3rem;
  }

  .btn-primary {
    font-family: 'Oswald', sans-serif;
    font-size: 0.9rem;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    text-decoration: none;
    background-color: #F5A623;
    color: #0d0d0d;
    padding: 0.9rem 2rem;
    border: 2px solid #F5A623;
    transition: all 0.2s;
    display: inline-block;
  }

  .btn-primary:hover {
    background-color: #c4811a;
    border-color: #c4811a;
    color: #0d0d0d;
  }

  .btn-secondary {
    font-family: 'Oswald', sans-serif;
    font-size: 0.9rem;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    text-decoration: none;
    background-color: transparent;
    color: #F5A623;
    padding: 0.9rem 2rem;
    border: 2px solid #F5A623;
    transition: all 0.2s;
    display: inline-block;
  }

  .btn-secondary:hover {
    background-color: #F5A623;
    color: #0d0d0d;
  }

  .hero-stats {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 2rem;
    flex-wrap: wrap;
  }

  .stat { text-align: center; }

  .stat-num {
    display: block;
    font-family: 'Special Elite', cursive;
    font-size: clamp(1.8rem, 5vw, 2.5rem);
    color: #F5A623;
  }

  .stat-label {
    display: block;
    font-family: 'Oswald', sans-serif;
    font-size: 0.7rem;
    color: #ffffff;
    letter-spacing: 1px;
    opacity: 0.6;
    text-transform: uppercase;
  }

  .stat-sep {
    font-family: 'Oswald', sans-serif;
    color: #6B7C45;
    font-size: 1.5rem;
    opacity: 0.5;
  }

  /* RASSURANT */
  .reassurance {
    padding: 4rem 0;
    border-bottom: 1px solid #222;
  }

  .reassurance-inner {
    max-width: 800px;
    margin: 0 auto;
  }

  .reassurance-label {
    font-family: 'Oswald', sans-serif;
    font-size: 0.75rem;
    color: #6B7C45;
    letter-spacing: 4px;
    margin-bottom: 1.5rem;
  }

  .reassurance-texte {
    font-size: 1.1rem;
    line-height: 1.9;
    margin-bottom: 2rem;
    color: #ffffff;
    font-weight: 300;
  }

  .reassurance-texte em {
    color: #F5A623;
    font-style: normal;
    font-weight: 700;
  }

  .reassurance-points {
    display: flex;
    flex-direction: column;
    gap: 0.8rem;
  }

  .point {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    font-family: 'Oswald', sans-serif;
    font-size: 0.95rem;
    letter-spacing: 1px;
    color: #ffffff;
    font-weight: 300;
  }

  .point-icon {
    color: #F5A623;
    font-size: 1rem;
    flex-shrink: 0;
    margin-top: 0.1rem;
    font-weight: 700;
  }

  /* DEMARRER */
  .demarrer {
    padding: 4rem 0;
    border-bottom: 1px solid #222;
  }

  .section-label {
    font-family: 'Oswald', sans-serif;
    font-size: 0.75rem;
    color: #6B7C45;
    letter-spacing: 4px;
    margin-bottom: 1rem;
  }

  .demarrer h2,
  .rubriques h2,
  .quiz-cta h2 {
    font-family: 'Special Elite', cursive;
    font-size: clamp(1.6rem, 4vw, 2.2rem);
    color: #F5A623;
    margin-bottom: 0.5rem;
    border: none;
    padding: 0;
  }

  .demarrer > p {
    color: #ffffff;
    opacity: 0.7;
    margin-bottom: 2.5rem;
    font-weight: 300;
  }

  .missions {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }

  @media (min-width: 600px) {
    .missions { grid-template-columns: repeat(3, 1fr); }
  }

  .mission {
    background-color: #0d0d0d;
    border: 1px solid #333;
    border-top: 4px solid #F5A623;
    padding: 1.5rem;
  }

  .mission-num {
    font-family: 'Special Elite', cursive;
    font-size: 2.5rem;
    color: #333;
    line-height: 1;
    margin-bottom: 0.8rem;
  }

  .mission h3 {
    font-family: 'Oswald', sans-serif;
    font-size: 1.1rem;
    font-weight: 700;
    color: #ffffff;
    letter-spacing: 1px;
    margin-bottom: 0.5rem;
    border: none;
    padding: 0;
  }

  .mission p {
    font-size: 0.85rem;
    color: #ffffff;
    opacity: 0.7;
    margin-bottom: 1rem;
    font-weight: 300;
  }

  .mission-lien {
    font-family: 'Oswald', sans-serif;
    font-size: 0.85rem;
    font-weight: 700;
    color: #F5A623;
    text-decoration: none;
    letter-spacing: 1px;
    transition: opacity 0.2s;
  }

  .mission-lien:hover { opacity: 0.7; }

  /* RUBRIQUES */
  .rubriques {
    padding: 4rem 0;
    border-bottom: 1px solid #222;
  }

  .rubriques-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
    margin-top: 2rem;
  }

  @media (min-width: 768px) {
    .rubriques-grid { grid-template-columns: repeat(3, 1fr); }
  }

  .rubrique-card {
    background-color: #0d0d0d;
    border: 1px solid #333;
    border-left: 4px solid #F5A623;
    padding: 1.5rem 1.2rem;
    text-decoration: none;
    transition: border-left-color 0.2s, transform 0.2s;
    display: block;
    position: relative;
  }

  .rubrique-card:hover {
    border-left-color: #8B2500;
    transform: translateY(-2px);
  }

  .rubrique-card-special {
    border-left-color: #F5A623;
    background-color: #0d0d0a;
  }

  .rubrique-card-special:hover {
    border-left-color: #F5A623;
    background-color: #111100;
  }

  .rubrique-badge {
    position: absolute;
    top: 0.8rem;
    right: 0.8rem;
    font-family: 'Oswald', sans-serif;
    font-size: 0.6rem;
    font-weight: 700;
    color: #0d0d0d;
    background-color: #F5A623;
    padding: 0.15rem 0.4rem;
    letter-spacing: 1px;
  }

  .rubrique-icon {
    width: 52px;
    height: 52px;
    margin-bottom: 1rem;
  }

  .rubrique-icon svg { width: 100%; height: 100%; }

  .rubrique-card h3 {
    font-family: 'Oswald', sans-serif;
    font-size: 1rem;
    font-weight: 700;
    color: #ffffff;
    letter-spacing: 1px;
    margin-bottom: 0.4rem;
    border: none;
    padding: 0;
  }

  .rubrique-card p {
    font-size: 0.8rem;
    color: #ffffff;
    opacity: 0.6;
    margin: 0;
    font-weight: 300;
  }

  /* QUIZ CTA */
  .quiz-cta {
    padding: 4rem 0;
    text-align: center;
  }

  .quiz-cta-inner {
    max-width: 700px;
    margin: 0 auto;
    border: 2px solid #F5A623;
    padding: 3rem 2rem;
    position: relative;
  }

  .quiz-cta-inner::before {
    content: '';
    position: absolute;
    top: 8px;
    left: 8px;
    right: -8px;
    bottom: -8px;
    border: 1px solid #333;
    z-index: -1;
  }

  .quiz-cta .section-label { margin-bottom: 1rem; }

  .quiz-cta p {
    color: #ffffff;
    opacity: 0.8;
    margin-bottom: 2rem;
    max-width: 500px;
    margin-left: auto;
    margin-right: auto;
    font-weight: 300;
  }
</style>