---
import Layout from '../../layouts/Layout.astro';

const articles = [
  {
    titre: "Quelle radio d'urgence acheter ? Le test honnête",
    url: "/bazar/radio-urgence-que-acheter",
    description: "On a teste les meilleures radios du marche pour toi."
  },
  {
    titre: "La trousse de secours voiture",
    url: "/bazar/trousse-secours-voiture",
    description: "Pas la trousse inutile du supermarche. La vraie."
  }
]
---

<Layout title="Le Bazar - Survivalix">
  <h1>Le Bazar</h1>
  <p>Tests et recommandations de materiel de survie.</p>
  <ul>
    {articles.map(article => (
      <li>
        <a href={article.url}>{article.titre}</a>
        <p>{article.description}</p>
      </li>
    ))}
  </ul>
</Layout>