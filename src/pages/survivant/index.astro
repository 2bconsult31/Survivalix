---
import Layout from '../../layouts/Layout.astro';
---

<Layout
  title="Quel Survivant es-tu ? — Survivalix"
  description="Découvre ton profil de survivant en 10 questions. Bâtisseur, Stratège, Soigneur ou Touriste ? Télécharge ta carte collector personnalisée."
>

  <div class="quiz-header">
    <div class="quiz-label">// IDENTIFICATION DU CITOYEN //</div>
    <h1>Quel Survivant es-tu ?</h1>
    <p class="quiz-desc">10 questions. 10 archétypes. Un seul profil — le tien. Découvre ton rôle naturel en situation de crise et télécharge ta carte collector.</p>
    <div class="quiz-meta">
      <span>10 questions</span>
      <span class="sep">//</span>
      <span>2 minutes</span>
      <span class="sep">//</span>
      <span>Carte collector à télécharger</span>
    </div>
  </div>

  <div class="quiz-wrapper">

    <!-- PROGRESS -->
    <div class="quiz-progress">
      <div class="progress-header">
        <span class="progress-label" id="progressNum">QUESTION 1 / 10</span>
        <span class="progress-pct" id="progressPct">0%</span>
      </div>
      <div class="progress-bar">
        <div class="progress-fill" id="progressFill" style="width: 0%"></div>
      </div>
    </div>

    <!-- QUESTION -->
    <div class="question-card" id="questionCard">
      <div class="question-num" id="questionNum">01</div>
      <h2 class="question-text" id="questionText"></h2>
      <div class="answers-list" id="answersGrid"></div>
    </div>

  </div>

</Layout>

<script is:inline>
  const questions = [
    {
      text: "La tempête coupe l'électricité. Ton premier réflexe ?",
      answers: [
        { text: "Je sors mes lampes frontales et ma radio à piles — tout est dans le tiroir prévu.", scores: { batisseur: 2, stratege: 1 } },
        { text: "Je vérifie les blessés et l'état de santé de tout le monde.", scores: { soigneur: 2, nourricier: 1 } },
        { text: "Je cherche ce qui peut être récupéré ou réparé dans la maison.", scores: { bricoleur: 2, technicien: 1 } },
        { text: "Je sors voir ce qui se passe dehors et évalue la situation.", scores: { explorateur: 2, chasseur: 1 } },
        { text: "Je tweete 'sans électricité lol' et j'attends que ça revienne.", scores: { touriste: 3 } }
      ]
    },
    {
      text: "Tu dois nourrir un groupe de 6 personnes avec ce qu'il y a dans les placards. Tu fais quoi ?",
      answers: [
        { text: "J'inventorie tout, je calcule les calories disponibles et je planifie les repas sur 3 jours.", scores: { stratege: 2, batisseur: 1 } },
        { text: "Je cuisine quelque chose de bon avec ce qu'il y a — la morale du groupe c'est important.", scores: { nourricier: 3 } },
        { text: "Je pars chercher ce qui manque dans les environs.", scores: { chasseur: 2, explorateur: 1 } },
        { text: "Je demande si quelqu'un a une allergie et je gère les soins si besoin.", scores: { soigneur: 2 } },
        { text: "Je commande sur Uber Eats et je réalise qu'il n'y a pas de réseau.", scores: { touriste: 3 } }
      ]
    },
    {
      text: "Quelqu'un se blesse. Que fais-tu en premier ?",
      answers: [
        { text: "Je sors la trousse de premiers secours et j'évalue la blessure.", scores: { soigneur: 3 } },
        { text: "Je cherche du matériel de fortune pour improviser un pansement.", scores: { bricoleur: 2, soigneur: 1 } },
        { text: "Je reste calme, je coordonne les autres et je prends les décisions.", scores: { stratege: 2, batisseur: 1 } },
        { text: "Je pars chercher de l'aide ou un médecin.", scores: { explorateur: 2, chasseur: 1 } },
        { text: "Je filme pour mettre sur Instagram en attendant que quelqu'un d'autre gère.", scores: { touriste: 3 } }
      ]
    },
    {
      text: "On doit établir un camp temporaire. Ton rôle naturel ?",
      answers: [
        { text: "Je construis les abris et j'organise l'espace logiquement.", scores: { batisseur: 3 } },
        { text: "Je pars en reconnaissance pour trouver eau, nourriture et ressources.", scores: { chasseur: 2, explorateur: 1 } },
        { text: "Je m'assure que tout le monde va bien et je gère les tensions.", scores: { soigneur: 2, nourricier: 1 } },
        { text: "Je m'occupe des systèmes de communication et d'éclairage.", scores: { technicien: 3 } },
        { text: "Je m'installe confortablement et je demande quand le camp sera prêt.", scores: { touriste: 3 } }
      ]
    },
    {
      text: "Tu as 200€ et une heure pour préparer un kit d'urgence. Tu achètes quoi en priorité ?",
      answers: [
        { text: "Eau, nourriture longue durée, couvertures de survie — les bases d'abord.", scores: { batisseur: 2, stratege: 1 } },
        { text: "Du matériel médical complet et des médicaments de base.", scores: { soigneur: 3 } },
        { text: "Une radio, des piles, une batterie externe et une lampe frontale.", scores: { technicien: 2, bricoleur: 1 } },
        { text: "Des vivres pour cuisiner de vrais repas même en crise.", scores: { nourricier: 2, chasseur: 1 } },
        { text: "Des snacks, un livre et des chargeurs — si ça dure je vais m'ennuyer.", scores: { touriste: 3 } }
      ]
    },
    {
      text: "Une crise dure depuis 5 jours. Comment tu maintiens le moral du groupe ?",
      answers: [
        { text: "Je cuisine quelque chose de bon — un vrai repas change tout.", scores: { nourricier: 3 } },
        { text: "J'organise les tâches clairement pour que personne ne tourne en rond.", scores: { stratege: 2, batisseur: 1 } },
        { text: "J'écoute, je soutiens, je détecte qui est à bout.", scores: { soigneur: 3 } },
        { text: "Je pars explorer et je reviens avec de bonnes nouvelles.", scores: { explorateur: 2, fantome: 1 } },
        { text: "Je propose de jouer aux cartes et je mange les réserves d'urgence.", scores: { touriste: 3 } }
      ]
    },
    {
      text: "Tu dois traverser une zone inconnue. Comment tu procèdes ?",
      answers: [
        { text: "Je cartographie mentalement, je repère les points d'eau et les abris.", scores: { explorateur: 3 } },
        { text: "Je passe inaperçu, j'observe avant d'agir, je ne laisse pas de traces.", scores: { fantome: 3 } },
        { text: "Je planifie l'itinéraire le plus sûr et je prévois des alternatives.", scores: { stratege: 2, explorateur: 1 } },
        { text: "Je pars en éclaireur et je reviens faire mon rapport.", scores: { chasseur: 2, fantome: 1 } },
        { text: "Je cherche la prochaine ville avec un hôtel et du WiFi.", scores: { touriste: 3 } }
      ]
    },
    {
      text: "Le groupe manque d'eau potable. Ta solution ?",
      answers: [
        { text: "Je construis un système de collecte d'eau de pluie.", scores: { batisseur: 2, bricoleur: 1 } },
        { text: "Je pars trouver une source et je vérifie si elle est potable.", scores: { chasseur: 3 } },
        { text: "J'utilise les pastilles de purification que j'ai dans mon kit.", scores: { stratege: 2, technicien: 1 } },
        { text: "Je bricole un filtre avec ce qu'on a sous la main.", scores: { bricoleur: 3 } },
        { text: "Je vérifie si j'ai encore de l'Evian dans mon sac à dos.", scores: { touriste: 3 } }
      ]
    },
    {
      text: "Les communications sont coupées. Comment tu restes informé ?",
      answers: [
        { text: "Ma radio à manivelle capte les fréquences d'urgence.", scores: { technicien: 2, stratege: 1 } },
        { text: "Je pars en reconnaissance pour collecter des infos sur le terrain.", scores: { explorateur: 2, chasseur: 1 } },
        { text: "J'observe les signaux naturels — météo, comportement animal, fumée.", scores: { fantome: 2, chasseur: 1 } },
        { text: "Je répare ou bricole un système de communication de fortune.", scores: { bricoleur: 2, technicien: 1 } },
        { text: "J'attends que quelqu'un vienne m'expliquer ce qui se passe.", scores: { touriste: 3 } }
      ]
    },
    {
      text: "La crise est terminée. Quelle est ta première réaction ?",
      answers: [
        { text: "J'analyse ce qui a bien ou mal fonctionné pour être mieux préparé.", scores: { stratege: 2, batisseur: 1 } },
        { text: "Je vérifie l'état de santé de tout le monde et je soigne les séquelles.", scores: { soigneur: 3 } },
        { text: "Je reconstruis et j'améliore ce qui peut l'être.", scores: { batisseur: 2, bricoleur: 1 } },
        { text: "Je disparais dans la nature pour souffler — j'ai besoin de solitude.", scores: { fantome: 2, explorateur: 1 } },
        { text: "Je poste un thread sur X en racontant comment j'ai 'survécu'.", scores: { touriste: 3 } }
      ]
    }
  ];

  const archetypes = {
    batisseur: { nom: "Le Bâtisseur", slug: "batisseur" },
    chasseur: { nom: "Le Chasseur", slug: "chasseur" },
    soigneur: { nom: "Le Soigneur", slug: "soigneur" },
    bricoleur: { nom: "Le Bricoleur", slug: "bricoleur" },
    stratege: { nom: "Le Stratège", slug: "stratege" },
    nourricier: { nom: "Le Nourricier", slug: "nourricier" },
    explorateur: { nom: "L'Explorateur", slug: "explorateur" },
    technicien: { nom: "Le Technicien", slug: "technicien" },
    fantome: { nom: "Le Fantôme", slug: "fantome" },
    touriste: { nom: "Le Touriste", slug: "touriste" }
  };

  let currentQuestion = 0;
  let scores = {
    batisseur: 0, chasseur: 0, soigneur: 0, bricoleur: 0,
    stratege: 0, nourricier: 0, explorateur: 0, technicien: 0,
    fantome: 0, touriste: 0
  };

  function renderQuestion() {
    const q = questions[currentQuestion];
    const pct = Math.round((currentQuestion / questions.length) * 100);

    document.getElementById('progressFill').style.width = `${pct}%`;
    document.getElementById('progressNum').textContent = `QUESTION ${currentQuestion + 1} / ${questions.length}`;
    document.getElementById('progressPct').textContent = `${pct}%`;
    document.getElementById('questionNum').textContent = String(currentQuestion + 1).padStart(2, '0');
    document.getElementById('questionText').textContent = q.text;

    const grid = document.getElementById('answersGrid');
    grid.innerHTML = '';

    const letters = ['A', 'B', 'C', 'D', 'E'];

    q.answers.forEach((answer, i) => {
      const btn = document.createElement('button');
      btn.className = 'answer-btn';
      btn.innerHTML = `
        <span class="answer-letter">${letters[i]}</span>
        <span class="answer-text">${answer.text}</span>
      `;
      btn.onclick = () => selectAnswer(answer.scores, btn);
      grid.appendChild(btn);
    });
  }

  function selectAnswer(answerScores, btn) {
    document.querySelectorAll('.answer-btn').forEach(b => b.disabled = true);
    btn.classList.add('answer-selected');

    Object.entries(answerScores).forEach(([key, val]) => {
      scores[key] += val;
    });

    setTimeout(() => {
      currentQuestion++;
      if (currentQuestion < questions.length) {
        const card = document.getElementById('questionCard');
        card.style.opacity = '0';
        card.style.transform = 'translateY(12px)';
        setTimeout(() => {
          renderQuestion();
          card.style.transition = 'opacity 0.3s ease, transform 0.3s ease';
          card.style.opacity = '1';
          card.style.transform = 'translateY(0)';
        }, 250);
      } else {
        showResult();
      }
    }, 700);
  }

  function showResult() {
    document.getElementById('progressFill').style.width = '100%';
    document.getElementById('progressNum').textContent = 'TERMINÉ';
    document.getElementById('progressPct').textContent = '100%';

    const winner = Object.entries(scores).reduce((a, b) => a[1] > b[1] ? a : b)[0];
    const params = new URLSearchParams({ profil: winner });
    window.location.href = `/survivant/resultat?${params.toString()}`;
  }

  renderQuestion();
</script>

<style>
  /* HEADER */
  .quiz-header {
    text-align: center;
    padding: 3rem 0 2.5rem;
    border-bottom: 1px solid #1a1a1a;
    margin-bottom: 3rem;
  }

  .quiz-label {
    font-family: 'Oswald', sans-serif;
    font-size: 0.75rem;
    color: #6B7C45;
    letter-spacing: 4px;
    margin-bottom: 1rem;
  }

  .quiz-header h1 {
    font-family: 'Special Elite', cursive;
    font-size: clamp(1.8rem, 5vw, 3.2rem);
    color: #F5A623;
    letter-spacing: 3px;
    margin-bottom: 1rem;
  }

  .quiz-desc {
    font-size: 1rem;
    font-weight: 300;
    max-width: 600px;
    margin: 0 auto 1.2rem;
    line-height: 1.7;
    opacity: 0.8;
  }

  .quiz-meta {
    font-family: 'Oswald', sans-serif;
    font-size: 0.75rem;
    color: #555;
    letter-spacing: 2px;
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .quiz-meta .sep { color: #2a2a2a; }

  /* WRAPPER */
  .quiz-wrapper {
    max-width: 720px;
    margin: 0 auto;
  }

  /* PROGRESS */
  .quiz-progress {
    margin-bottom: 2.5rem;
  }

  .progress-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 0.6rem;
  }

  .progress-label {
    font-family: 'Oswald', sans-serif;
    font-size: 0.7rem;
    color: #F5A623;
    letter-spacing: 3px;
    font-weight: 700;
  }

  .progress-pct {
    font-family: 'Special Elite', cursive;
    font-size: 0.9rem;
    color: #F5A623;
  }

  .progress-bar {
    height: 4px;
    background-color: #1a1a1a;
    border: 1px solid #222;
    position: relative;
  }

  .progress-fill {
    height: 100%;
    background-color: #F5A623;
    transition: width 0.5s ease;
    box-shadow: 0 0 8px rgba(245, 166, 35, 0.4);
  }

  /* QUESTION CARD */
  .question-card {
    background-color: #0d0d0d;
    border: 1px solid #1e1e1e;
    border-top: 4px solid #F5A623;
    padding: 2.5rem 2rem;
    transition: opacity 0.3s ease, transform 0.3s ease;
  }

  .question-num {
    font-family: 'Special Elite', cursive;
    font-size: 4rem;
    color: #1a1a1a;
    line-height: 1;
    margin-bottom: 1rem;
    letter-spacing: 2px;
  }

  .question-text {
    font-family: 'Special Elite', cursive;
    font-size: clamp(1.1rem, 3vw, 1.5rem);
    color: #F5A623;
    line-height: 1.4;
    margin-bottom: 2rem;
    border: none !important;
    padding: 0 !important;
    letter-spacing: 0.5px;
  }

  /* ANSWERS */
  .answers-list {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .answer-btn {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    width: 100%;
    background-color: #111;
    border: 1px solid #222;
    border-left: 3px solid #222;
    padding: 1rem 1.2rem;
    cursor: pointer;
    text-align: left;
    transition: all 0.2s;
    position: relative;
  }

  .answer-btn:hover:not(:disabled) {
    border-left-color: #F5A623;
    background-color: #161600;
  }

  .answer-btn:disabled { cursor: not-allowed; }

  .answer-btn:disabled:not(.answer-selected) {
    opacity: 0.4;
  }

  .answer-letter {
    font-family: 'Special Elite', cursive;
    font-size: 1rem;
    color: #333;
    flex-shrink: 0;
    width: 24px;
    height: 24px;
    border: 1px solid #333;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-top: 1px;
    transition: all 0.2s;
    font-size: 0.8rem;
  }

  .answer-btn:hover:not(:disabled) .answer-letter {
    border-color: #F5A623;
    color: #F5A623;
  }

  .answer-text {
    font-family: 'Oswald', sans-serif;
    font-size: 0.92rem;
    font-weight: 300;
    color: #ffffff;
    line-height: 1.55;
    letter-spacing: 0.3px;
    flex: 1;
  }

  /* SELECTED */
  .answer-selected {
    border-left-color: #F5A623 !important;
    background-color: #1a1600 !important;
    opacity: 1 !important;
  }

  .answer-selected .answer-letter {
    background-color: #F5A623;
    border-color: #F5A623;
    color: #0d0d0d !important;
  }

  .answer-selected .answer-text {
    color: #F5A623 !important;
  }

  @media (max-width: 600px) {
    .question-card { padding: 1.5rem 1rem; }
    .question-num { font-size: 2.5rem; }
  }
</style>