---
import Layout from '../../layouts/Layout.astro';
---

<Layout
  title="Ton profil Survivant — Survivalix"
  description="Découvre ton archétype de survivant et télécharge ta carte collector personnalisée."
>
  <div id="resultat-container">
    <div class="loading-state">
      <div class="loading-dots"><span></span><span></span><span></span></div>
      <p>Analyse de ton profil en cours...</p>
    </div>
  </div>
</Layout>

<script is:inline>
  const archetypes = {
    batisseur: {
      nom: "Le Bâtisseur",
      tagline: "Tu construis pendant que les autres parlent.",
      description: "En situation de crise, tu passes à l'action. Tu organises l'espace, tu construis les abris, tu prépares le terrain. Le groupe compte sur toi pour transformer le chaos en ordre. Tu n'as pas besoin qu'on te dise quoi faire — tu vois ce qui manque et tu le fais.",
      couleur: "#8B2500",
      conseil: "Ton kit 72h est probablement déjà prêt. Pense à documenter tes méthodes pour que le groupe puisse reproduire sans toi."
    },
    chasseur: {
      nom: "Le Chasseur",
      tagline: "Là où les autres voient un problème, tu vois des ressources.",
      description: "Tu connais le terrain. Tu sais trouver l'eau, la nourriture, les ressources que personne d'autre ne voit. Autonome et efficace, tu assures la survie matérielle du groupe. Sans toi, tout le monde aurait faim.",
      couleur: "#6B7C45",
      conseil: "Apprends à déléguer — ton groupe a besoin de tes connaissances terrain, pas seulement de tes résultats."
    },
    soigneur: {
      nom: "Le Soigneur",
      tagline: "Tu gardes tout le monde en vie — physiquement et moralement.",
      description: "Tu es la colonne vertébrale humaine du groupe. Tu soignes les blessures, tu détectes la détresse psychologique, tu maintiens le moral quand tout s'effondre. Sans toi, le groupe survivrait peut-être — mais il ne tiendrait pas longtemps ensemble.",
      couleur: "#F5A623",
      conseil: "Forme-toi aux premiers secours si ce n'est pas déjà fait. Une certification PSC1 peut changer des vies — littéralement."
    },
    bricoleur: {
      nom: "Le Bricoleur",
      tagline: "Tu répares l'irréparable avec trois bouts de ficelle.",
      description: "Ton superpouvoir c'est l'improvisation. Tu vois le potentiel dans les objets cassés, tu trouves des solutions là où les autres voient des obstacles. Un filtre à eau en plastique recyclé ? Un générateur de fortune ? Tu l'as déjà fait.",
      couleur: "#c4811a",
      conseil: "Constitue une boîte à outils d'urgence portable. Duct tape, couteau multifonction, fil de nylon — tes alliés en toutes circonstances."
    },
    stratege: {
      nom: "Le Stratège",
      tagline: "Tu penses à demain quand les autres pensent à maintenant.",
      description: "Tu planifies, tu anticipes, tu prends les décisions difficiles. Tu vois la situation dans son ensemble là où les autres sont dans l'urgence. Le groupe te fait confiance pour choisir la bonne direction. Parfois froid, toujours efficace.",
      couleur: "#2d6a8f",
      conseil: "Prépare un plan d'évacuation familial. Un Stratège sans plan écrit n'est qu'un improvisateur qui se croit organisé."
    },
    nourricier: {
      nom: "Le Nourricier",
      tagline: "Tu nourris le corps et l'âme du groupe.",
      description: "La cuisine c'est ton terrain de jeu même en crise. Tu transformes des conserves en repas dignes, tu maintiens les rituels du quotidien pour garder le moral, tu gères les stocks avec une précision chirurgicale. Personne n'a faim quand tu es là.",
      couleur: "#8B5E3C",
      conseil: "Commence à stocker ce que tu cuisines vraiment. Un stock de 2 semaines de tes recettes habituelles vaut mieux que 3 mois de rations militaires que tu n'ouvriras jamais."
    },
    explorateur: {
      nom: "L'Explorateur",
      tagline: "Tu cartographies l'inconnu pour que les autres avancent.",
      description: "Tu as besoin de savoir ce qu'il y a de l'autre côté. Tu pars en reconnaissance, tu cartographies, tu reviens avec des informations que personne d'autre n'aurait. Curieux, mobile, indépendant — tu es les yeux du groupe.",
      couleur: "#2d6a4f",
      conseil: "Apprends à lire une carte topographique et à utiliser une boussole. Le GPS tombe en panne — tes compétences, non."
    },
    technicien: {
      nom: "Le Technicien",
      tagline: "Tu maintiens le lien avec le monde quand tout s'effondre.",
      description: "La technologie ne te fait pas peur même quand elle est cassée. Tu répares les radios, tu crées des systèmes de communication, tu gères l'énergie et l'éclairage. Sans toi, le groupe serait aveugle et sourd.",
      couleur: "#1a4a6b",
      conseil: "Investis dans une radio à manivelle et une batterie solaire. Ce sont les deux équipements que tout Technicien devrait avoir dans son kit."
    },
    fantome: {
      nom: "Le Fantôme",
      tagline: "Tu passes là où les autres ne peuvent pas aller.",
      description: "Discret, observateur, insaisissable. Tu te déplaces sans laisser de traces, tu évalues les situations sans te faire repérer, tu apparais quand on a besoin de toi et disparais dans l'ombre. Ton silence est une force.",
      couleur: "#3a3a4a",
      conseil: "Ton indépendance est une force — mais en crise, l'isolement tue. Apprends à communiquer tes observations au groupe."
    },
    touriste: {
      nom: "Le Touriste",
      tagline: "Tu cherches le WiFi depuis le début.",
      description: "Soyons honnêtes — la survie c'est pas vraiment ton truc. Tu as survécu à cette crise grâce aux autres, et tu leur dois probablement une fière chandelle. La bonne nouvelle : tu t'en es sorti vivant. La mauvaise : tu as mangé les réserves d'urgence un mardi soir. Il est temps de lire Survivalix sérieusement.",
      couleur: "#555555",
      conseil: "Commence par le commencement : lis notre guide kit 72h. Maintenant. Pas demain. Maintenant."
    }
  };

  function init() {
    const params = new URLSearchParams(window.location.search);
    const profil = params.get('profil');

    if (!profil || !archetypes[profil]) {
      window.location.href = '/survivant';
      return;
    }

    const a = archetypes[profil];
    const container = document.getElementById('resultat-container');

    container.innerHTML = `
      <div class="result-header">
        <div class="result-label">// TON PROFIL SURVIVANT //</div>
        <div class="result-badge" style="border-color: ${a.couleur}; color: ${a.couleur}">
          ARCHÉTYPE IDENTIFIÉ
        </div>
        <h1 class="result-nom" style="color: ${a.couleur}">${a.nom}</h1>
        <p class="result-tagline">${a.tagline}</p>
      </div>

      <div class="result-body">

        <div class="result-card">
          <div class="card-label">// ANALYSE //</div>
          <p class="result-description">${a.description}</p>
        </div>

        <div class="result-card result-card-conseil">
          <div class="card-label">// CONSEIL SURVIVALIX //</div>
          <p class="result-conseil">${a.conseil}</p>
        </div>

        <div class="result-actions">
          <div class="actions-label">// ET MAINTENANT ? //</div>
          <div class="actions-grid">
            <a href="/survivant" class="action-btn action-btn-secondary">
              <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <polyline points="1,4 1,10 7,10" stroke="#F5A623" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                <path d="M3.51 15a9 9 0 1 0 .49-4.95" stroke="#F5A623" stroke-width="1.5" stroke-linecap="round"/>
              </svg>
              Refaire le quiz
            </a>
            <a href="/manuel/kit-urgence-72h" class="action-btn action-btn-primary">
              <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20" stroke="#0d0d0d" stroke-width="1.5" stroke-linecap="round"/>
                <path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z" stroke="#0d0d0d" stroke-width="1.5"/>
              </svg>
              Lire le Manuel
            </a>
          </div>
        </div>

        <div class="share-block">
          <div class="share-label">// PARTAGER TON PROFIL //</div>
          <p class="share-desc">Tu es ${a.nom} — et toi, quel Survivant es-tu ? Partage le quiz.</p>
          <div class="share-buttons">
            <button class="share-btn" onclick="copyLink()">
              <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71" stroke="#F5A623" stroke-width="1.5" stroke-linecap="round"/>
                <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71" stroke="#F5A623" stroke-width="1.5" stroke-linecap="round"/>
              </svg>
              <span id="copyBtnText">Copier le lien</span>
            </button>
          </div>
        </div>

      </div>
    `;
  }

  function copyLink() {
    const url = window.location.href;
    navigator.clipboard.writeText(url).then(() => {
      const btn = document.getElementById('copyBtnText');
      btn.textContent = 'Lien copié !';
      setTimeout(() => { btn.textContent = 'Copier le lien'; }, 2000);
    });
  }

  init();
</script>

<style>
  .loading-state {
    text-align: center;
    padding: 4rem 0;
  }

  .loading-dots {
    display: flex;
    gap: 8px;
    justify-content: center;
    margin-bottom: 1rem;
  }

  .loading-dots span {
    width: 8px;
    height: 8px;
    background-color: #F5A623;
    border-radius: 50%;
    animation: dot 1.2s infinite;
  }

  .loading-dots span:nth-child(2) { animation-delay: 0.2s; }
  .loading-dots span:nth-child(3) { animation-delay: 0.4s; }

  @keyframes dot {
    0%, 60%, 100% { opacity: 0.2; transform: scale(0.8); }
    30% { opacity: 1; transform: scale(1); }
  }

  /* RESULT HEADER */
  .result-header {
    text-align: center;
    padding: 3rem 0 2.5rem;
    border-bottom: 1px solid #1a1a1a;
    margin-bottom: 3rem;
  }

  .result-label {
    font-family: 'Oswald', sans-serif;
    font-size: 0.75rem;
    color: #6B7C45;
    letter-spacing: 4px;
    margin-bottom: 1.2rem;
  }

  .result-badge {
    display: inline-block;
    font-family: 'Oswald', sans-serif;
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 4px;
    border: 1px solid;
    padding: 0.3rem 1rem;
    margin-bottom: 1.5rem;
  }

  .result-nom {
    font-family: 'Special Elite', cursive;
    font-size: clamp(2.5rem, 8vw, 5rem);
    line-height: 1;
    letter-spacing: 3px;
    margin-bottom: 1rem;
    border: none !important;
    padding: 0 !important;
  }

  .result-tagline {
    font-family: 'Special Elite', cursive;
    font-size: clamp(0.9rem, 2.5vw, 1.2rem);
    color: #ffffff;
    opacity: 0.7;
    font-style: italic;
    max-width: 500px;
    margin: 0 auto;
    line-height: 1.5;
  }

  /* RESULT BODY */
  .result-body {
    max-width: 720px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .result-card {
    background-color: #111;
    border: 1px solid #1e1e1e;
    border-top: 3px solid #F5A623;
    padding: 1.8rem;
  }

  .result-card-conseil {
    border-top-color: #6B7C45;
  }

  .card-label {
    font-family: 'Oswald', sans-serif;
    font-size: 0.68rem;
    color: #6B7C45;
    letter-spacing: 3px;
    margin-bottom: 1rem;
  }

  .result-description {
    font-family: 'Oswald', sans-serif;
    font-size: 1rem;
    color: #ffffff;
    line-height: 1.85;
    font-weight: 300;
    margin: 0;
  }

  .result-conseil {
    font-family: 'Oswald', sans-serif;
    font-size: 0.95rem;
    color: #ffffff;
    line-height: 1.8;
    font-weight: 300;
    font-style: italic;
    margin: 0;
    opacity: 0.85;
  }

  /* ACTIONS */
  .result-actions {
    background-color: #0d0d0d;
    border: 1px solid #1e1e1e;
    padding: 1.8rem;
  }

  .actions-label {
    font-family: 'Oswald', sans-serif;
    font-size: 0.68rem;
    color: #6B7C45;
    letter-spacing: 3px;
    margin-bottom: 1.2rem;
  }

  .actions-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  @media (max-width: 500px) {
    .actions-grid { grid-template-columns: 1fr; }
  }

  .action-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.6rem;
    font-family: 'Oswald', sans-serif;
    font-size: 0.88rem;
    font-weight: 700;
    letter-spacing: 1px;
    text-decoration: none;
    padding: 0.9rem 1.2rem;
    transition: all 0.2s;
    text-align: center;
  }

  .action-btn svg {
    width: 16px;
    height: 16px;
    flex-shrink: 0;
  }

  .action-btn-primary {
    background-color: #F5A623;
    color: #0d0d0d;
    border: 2px solid #F5A623;
  }

  .action-btn-primary:hover {
    background-color: #c4811a;
    border-color: #c4811a;
    color: #0d0d0d;
  }

  .action-btn-secondary {
    background-color: transparent;
    color: #F5A623;
    border: 2px solid #F5A623;
  }

  .action-btn-secondary:hover {
    background-color: #F5A623;
    color: #0d0d0d;
  }

  /* SHARE */
  .share-block {
    background-color: #0d0d0d;
    border: 1px solid #1e1e1e;
    border-left: 4px solid #F5A623;
    padding: 1.8rem;
  }

  .share-label {
    font-family: 'Oswald', sans-serif;
    font-size: 0.68rem;
    color: #6B7C45;
    letter-spacing: 3px;
    margin-bottom: 0.8rem;
  }

  .share-desc {
    font-size: 0.9rem;
    color: #ffffff;
    opacity: 0.7;
    font-weight: 300;
    margin-bottom: 1.2rem;
    line-height: 1.6;
  }

  .share-buttons {
    display: flex;
    gap: 0.8rem;
    flex-wrap: wrap;
  }

  .share-btn {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    font-family: 'Oswald', sans-serif;
    font-size: 0.82rem;
    font-weight: 700;
    color: #F5A623;
    background: none;
    border: 1px solid #F5A623;
    padding: 0.6rem 1.2rem;
    cursor: pointer;
    letter-spacing: 1px;
    transition: all 0.2s;
  }

  .share-btn:hover {
    background-color: #F5A623;
    color: #0d0d0d;
  }

  .share-btn svg {
    width: 16px;
    height: 16px;
    flex-shrink: 0;
  }
</style>