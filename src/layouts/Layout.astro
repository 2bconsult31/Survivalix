---
const { title } = Astro.props;
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Special+Elite&family=Oswald:wght@400;700&display=swap" rel="stylesheet" />
    <title>{title}</title>
  </head>
  <body>

    <div class="scanlines"></div>

    <header>
      <div class="header-inner">
        <a href="/" class="logo">
          <span class="logo-main">SURVIVALIX</span>
          <span class="logo-sub">// GUIDE DE SURVIE DU CITOYEN //</span>
        </a>
        <nav>
          <ul>
            <li><a href="/manuel">LE MANUEL</a></li>
            <li><a href="/cantine">LA CANTINE</a></li>
            <li><a href="/bazar">LE BAZAR</a></li>
            <li><a href="/atelier">L'ATELIER</a></li>
            <li><a href="/radar">LE RADAR</a></li>
            <li><a href="/outils">LES OUTILS</a></li>
            <li><a href="/survivant" class="cta">QUEL SURVIVANT ES-TU ?</a></li>
          </ul>
        </nav>
      </div>
    </header>

    <div class="hero-band">
      <span>⚠ NIVEAU D'ALERTE : MODÉRÉ</span>
      <span>|</span>
      <span>STOCK EAU : VÉRIFIER</span>
      <span>|</span>
      <span>KIT 72H : PRÉPARER</span>
      <span>|</span>
      <span>RESTEZ INFORMÉS. RESTEZ VIVANTS.</span>
    </div>

    <main>
      <slot />
    </main>

    <footer>
      <div class="footer-inner">
        <div class="footer-logo">SURVIVALIX</div>
        <p class="footer-tagline">Le site de survie pour les gens normaux.</p>
        <div class="footer-links">
          <a href="/a-propos">À propos</a>
          <a href="/contact">Contact</a>
          <a href="/mentions-legales">Mentions légales</a>
          <a href="/ressources">Ressources</a>
        </div>
        <p class="footer-copy">© 2025 Survivalix — Tous droits réservés</p>
      </div>
    </footer>

  </body>
</html>

<style>
  /* ============================================
     RESET & BASE
  ============================================ */
  *, *::before, *::after {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  :root {
    --noir: #0d0d0d;
    --noir-moyen: #1a1a1a;
    --noir-clair: #242424;
    --ambre: #F5A623;
    --ambre-fonce: #c4811a;
    --kaki: #6B7C45;
    --rouge: #8B2500;
    --creme: #F5E6C8;
    --gris: #888;
    --font-titre: 'Special Elite', cursive;
    --font-nav: 'Oswald', sans-serif;
  }

  html, body {
    width: 100%;
    min-height: 100%;
    background-color: var(--noir);
    color: var(--creme);
    font-family: 'Georgia', serif;
    font-size: 16px;
    line-height: 1.7;
  }

  /* ============================================
     EFFET SCANLINES
  ============================================ */
  .scanlines {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: repeating-linear-gradient(
      0deg,
      transparent,
      transparent 2px,
      rgba(0,0,0,0.03) 2px,
      rgba(0,0,0,0.03) 4px
    );
    pointer-events: none;
    z-index: 9999;
  }

  /* ============================================
     HEADER
  ============================================ */
  header {
    background-color: var(--noir);
    border-bottom: 3px solid var(--ambre);
    padding: 1.2rem 2rem;
    position: sticky;
    top: 0;
    z-index: 100;
  }

  .header-inner {
    max-width: 1300px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
  }

  .logo {
    text-decoration: none;
    text-align: center;
  }

  .logo-main {
    display: block;
    font-family: var(--font-titre);
    font-size: 2.8rem;
    color: var(--ambre);
    letter-spacing: 8px;
    text-shadow: 0 0 20px rgba(245, 166, 35, 0.4);
  }

  .logo-sub {
    display: block;
    font-family: var(--font-nav);
    font-size: 0.7rem;
    color: var(--kaki);
    letter-spacing: 4px;
    margin-top: -0.3rem;
  }

  nav ul {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.2rem;
  }

  nav ul a {
    display: block;
    font-family: var(--font-nav);
    font-size: 0.8rem;
    font-weight: 700;
    color: var(--creme);
    text-decoration: none;
    letter-spacing: 2px;
    padding: 0.4rem 0.8rem;
    border: 1px solid transparent;
    transition: all 0.2s;
  }

  nav ul a:hover {
    color: var(--ambre);
    border-color: var(--ambre);
  }

  nav ul .cta {
    background-color: var(--ambre);
    color: var(--noir) !important;
    border-color: var(--ambre);
  }

  nav ul .cta:hover {
    background-color: var(--ambre-fonce);
    border-color: var(--ambre-fonce);
  }

  /* ============================================
     HERO BAND
  ============================================ */
  .hero-band {
    background-color: var(--rouge);
    color: var(--creme);
    font-family: var(--font-nav);
    font-size: 0.75rem;
    letter-spacing: 2px;
    padding: 0.4rem 2rem;
    display: flex;
    justify-content: center;
    gap: 1.5rem;
    flex-wrap: wrap;
  }

  /* ============================================
     MAIN
  ============================================ */
  main {
    max-width: 1300px;
    margin: 0 auto;
    padding: 3rem 2rem;
  }

  h1 {
    font-family: var(--font-titre);
    font-size: 2.5rem;
    color: var(--ambre);
    margin-bottom: 1rem;
    letter-spacing: 2px;
  }

  h2 {
    font-family: var(--font-titre);
    font-size: 1.8rem;
    color: var(--creme);
    margin-bottom: 0.8rem;
    border-left: 4px solid var(--ambre);
    padding-left: 1rem;
  }

  p {
    color: var(--creme);
    margin-bottom: 1rem;
    opacity: 0.9;
  }

  a {
    color: var(--ambre);
  }

  ul {
    list-style: none;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1.5rem;
    margin-top: 2rem;
  }

  ul li {
    background-color: var(--noir-clair);
    border: 1px solid #333;
    border-left: 4px solid var(--ambre);
    padding: 1.5rem;
    transition: border-color 0.2s;
  }

  ul li:hover {
    border-left-color: var(--rouge);
  }

  ul li a {
    font-family: var(--font-nav);
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--creme);
    text-decoration: none;
    letter-spacing: 1px;
  }

  ul li a:hover {
    color: var(--ambre);
  }

  ul li p {
    font-size: 0.9rem;
    margin-top: 0.5rem;
    opacity: 0.7;
  }

  /* ============================================
     FOOTER
  ============================================ */
  footer {
    background-color: var(--noir);
    border-top: 3px solid var(--ambre);
    margin-top: 4rem;
    padding: 3rem 2rem;
  }

  .footer-inner {
    max-width: 1300px;
    margin: 0 auto;
    text-align: center;
  }

  .footer-logo {
    font-family: var(--font-titre);
    font-size: 2rem;
    color: var(--ambre);
    letter-spacing: 6px;
    margin-bottom: 0.5rem;
  }

  .footer-tagline {
    font-family: var(--font-nav);
    font-size: 0.85rem;
    color: var(--kaki);
    letter-spacing: 2px;
    margin-bottom: 1.5rem;
  }

  .footer-links {
    display: flex;
    justify-content: center;
    gap: 2rem;
    margin-bottom: 1.5rem;
    flex-wrap: wrap;
  }

  .footer-links a {
    font-family: var(--font-nav);
    font-size: 0.8rem;
    color: var(--creme);
    text-decoration: none;
    letter-spacing: 1px;
    opacity: 0.7;
    transition: opacity 0.2s;
  }

  .footer-links a:hover {
    opacity: 1;
    color: var(--ambre);
  }

  .footer-copy {
    font-size: 0.75rem;
    color: var(--gris);
    opacity: 0.5;
  }
</style>