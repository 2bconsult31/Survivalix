---
import '../styles/global.css';

const { 
  title, 
  description = "Survivalix — Le site de survie pour les gens normaux. Guides pratiques, recettes, outils interactifs et humour post-apo.",
  image = "/og-image.jpg"
} = Astro.props;

const url = Astro.url;
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Special+Elite&family=Oswald:wght@300;400;700&display=swap" rel="stylesheet" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={url} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={url} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={image} />
    <meta property="og:locale" content="fr_FR" />
    <meta property="og:site_name" content="Survivalix" />
    <meta name="robots" content="index, follow" />
  </head>
  <body>

    <div class="scanlines"></div>

    <header>
      <div class="header-inner">
        <div class="header-top">
          <a href="/" class="logo">
            <img src="/LOGO_OK.svg" alt="Survivalix" class="logo-img" />
          </a>
          <button class="menu-toggle" id="menuToggle" aria-label="Menu">
            <span></span>
            <span></span>
            <span></span>
          </button>
        </div>
        <nav id="mainNav">
          <ul>
            <li><a href="/manuel">LE MANUEL</a></li>
            <li><a href="/cantine">LA CANTINE</a></li>
            <li><a href="/bunker">LE BUNKER</a></li>
            <li><a href="/atelier">L'ATELIER</a></li>
            <li><a href="/radar">LE RADAR</a></li>
            <li><a href="/outils">LES OUTILS</a></li>
            <li><a href="/survivant" class="cta">QUEL SURVIVANT ES-TU ?</a></li>
          </ul>
        </nav>
      </div>
    </header>

    <div class="hero-band">
      <div class="ticker">
        <div class="ticker-inner">
          <span>⚠ NIVEAU D'ALERTE : MODÉRÉ</span>
          <span class="sep">///</span>
          <span>STOCK EAU : VÉRIFIER</span>
          <span class="sep">///</span>
          <span>RESTEZ INFORMÉS. RESTEZ VIVANTS.</span>
          <span class="sep">///</span>
          <span>KIT 72H : PRÉPARER DÈS MAINTENANT</span>
          <span class="sep">///</span>
          <span>⚠ NIVEAU D'ALERTE : MODÉRÉ</span>
          <span class="sep">///</span>
          <span>STOCK EAU : VÉRIFIER</span>
          <span class="sep">///</span>
          <span>RESTEZ INFORMÉS. RESTEZ VIVANTS.</span>
          <span class="sep">///</span>
          <span>KIT 72H : PRÉPARER DÈS MAINTENANT</span>
          <span class="sep">///</span>
        </div>
      </div>
    </div>

    <main>
      <slot />
    </main>

    <footer>
      <div class="footer-inner">
        <img src="/LOGO_OK.svg" alt="Survivalix" class="footer-logo-img" />
        <p class="footer-tagline">Le site de survie pour les gens normaux.</p>
        <div class="footer-links">
          <a href="/a-propos">À propos</a>
          <a href="/contact">Contact</a>
          <a href="/mentions-legales">Mentions légales</a>
          <a href="/ressources">Ressources</a>
        </div>
        <p class="footer-copy">© 2025 Survivalix — Tous droits réservés</p>
      </div>
    </footer>

  </body>
</html>

<script>
  const toggle = document.getElementById('menuToggle');
  const nav = document.getElementById('mainNav');
  toggle?.addEventListener('click', () => {
    nav?.classList.toggle('open');
    toggle.classList.toggle('active');
  });
</script>

<style>
  /* MAIN */
  main {
    max-width: 1300px;
    margin: 0 auto;
    padding: 2rem 1rem;
  }

  @media (min-width: 768px) {
    main { padding: 3rem 2rem; }
  }

  /* RESET NAV — empêche le global de transformer le nav en grille */
  header nav {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.3s ease;
  }

  header nav.open { max-height: 900px; }

  header nav ul {
    list-style: none !important;
    display: flex !important;
    flex-direction: column !important;
    padding: 0.8rem 0 !important;
    gap: 0 !important;
    margin: 0 !important;
    grid-template-columns: none !important;
    background: none !important;
  }

  header nav ul li {
    background: none !important;
    border: none !important;
    border-left: none !important;
    padding: 0 !important;
    display: block !important;
    transform: none !important;
  }

  header nav ul li:hover {
    background: none !important;
    border-left-color: transparent !important;
    transform: none !important;
  }

  header nav ul a {
    display: block;
    font-family: 'Oswald', sans-serif;
    font-size: 1.15rem !important;
    font-weight: 700;
    color: #F5E6C8;
    text-decoration: none;
    letter-spacing: 2px;
    padding: 1rem 1.5rem !important;
    border-left: 3px solid transparent;
    transition: all 0.2s;
    background-color: transparent !important;
    line-height: 1.4;
  }

  header nav ul a:hover {
    color: #F5A623;
    border-left-color: #F5A623;
    background-color: transparent !important;
  }

  header nav ul .cta {
    background-color: #F5A623 !important;
    color: #0d0d0d !important;
    border-left-color: #F5A623 !important;
    margin-top: 0.5rem;
    text-align: center;
    font-size: 1.15rem !important;
  }

  header nav ul .cta:hover { background-color: #c4811a !important; }

  @media (min-width: 768px) {
    .menu-toggle { display: none !important; }

    header nav {
      max-height: none !important;
      overflow: visible !important;
    }

    header nav ul {
      flex-direction: row !important;
      flex-wrap: wrap !important;
      justify-content: center !important;
      padding: 0.8rem 0 0 !important;
      gap: 0.2rem !important;
    }

    header nav ul a {
      padding: 0.5rem 1rem !important;
      border-left: none !important;
      border: 1px solid transparent !important;
      font-size: 0.82rem !important;
      line-height: normal !important;
    }

    header nav ul a:hover {
      border-color: #F5A623 !important;
      border-left-color: #F5A623 !important;
    }

    header nav ul .cta {
      margin-top: 0 !important;
      font-size: 0.82rem !important;
    }

    .header-top { justify-content: center; }
    .logo { text-align: center; }
  }

  /* CARTES RUBRIQUES — uniquement dans main */
  main ul {
    list-style: none;
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
    margin-top: 1.5rem;
  }

  @media (min-width: 600px) {
    main ul { grid-template-columns: repeat(2, 1fr); }
  }

  @media (min-width: 900px) {
    main ul { grid-template-columns: repeat(3, 1fr); }
  }

  main ul li {
    background-color: #0d0d0d;
    border: 1px solid #333;
    border-left: 4px solid #F5A623;
    padding: 1.2rem;
    transition: border-color 0.2s, transform 0.2s;
  }

  main ul li:hover {
    border-left-color: #8B2500;
    transform: translateY(-2px);
  }

  main ul li a {
    font-family: 'Oswald', sans-serif;
    font-size: 1rem;
    font-weight: 700;
    color: #F5E6C8;
    text-decoration: none;
    letter-spacing: 1px;
  }

  main ul li a:hover { color: #F5A623; }

  main ul li p {
    font-size: 0.85rem;
    margin-top: 0.5rem;
    opacity: 0.7;
    margin-bottom: 0;
  }
</style>