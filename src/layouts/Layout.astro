---
const { title } = Astro.props;
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body>

    <header>
      <nav>
        <a href="/" class="logo">SURVIVALIX</a>
        <ul>
          <li><a href="/manuel">Le Manuel</a></li>
          <li><a href="/cantine">La Cantine</a></li>
          <li><a href="/bazar">Le Bazar</a></li>
          <li><a href="/atelier">L'Atelier</a></li>
          <li><a href="/radar">Le Radar</a></li>
          <li><a href="/outils">Les Outils</a></li>
          <li><a href="/survivant" class="cta">Quel Survivant es-tu ?</a></li>
        </ul>
      </nav>
    </header>

    <main>
      <slot />
    </main>

    <footer>
      <p>© 2025 Survivalix — <a href="/mentions-legales">Mentions légales</a></p>
    </footer>

  </body>
</html>

<style>
  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  html, body {
    width: 100%;
    min-height: 100%;
    font-family: 'Georgia', serif;
    background-color: #1a1a1a;
    color: #F5E6C8;
  }

  /* HEADER */
  header {
    background-color: #1a1a1a;
    border-bottom: 3px solid #F5A623;
    padding: 1rem 2rem;
  }

  nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    max-width: 1200px;
    margin: 0 auto;
  }

  .logo {
    font-size: 1.8rem;
    font-weight: 900;
    color: #F5A623;
    text-decoration: none;
    letter-spacing: 3px;
  }

  nav ul {
    list-style: none;
    display: flex;
    gap: 1.5rem;
    align-items: center;
  }

  nav ul a {
    color: #F5E6C8;
    text-decoration: none;
    font-size: 0.9rem;
    text-transform: uppercase;
    letter-spacing: 1px;
    transition: color 0.2s;
  }

  nav ul a:hover {
    color: #F5A623;
  }

  .cta {
    background-color: #F5A623;
    color: #1a1a1a !important;
    padding: 0.5rem 1rem;
    font-weight: 700;
  }

  .cta:hover {
    background-color: #d4891e !important;
    color: #1a1a1a !important;
  }

  /* MAIN */
  main {
    max-width: 1200px;
    margin: 0 auto;
    padding: 2rem;
  }

  /* FOOTER */
  footer {
    border-top: 2px solid #333;
    padding: 1.5rem 2rem;
    text-align: center;
    color: #888;
    font-size: 0.85rem;
  }

  footer a {
    color: #F5A623;
    text-decoration: none;
  }
</style>