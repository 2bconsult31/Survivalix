---
const { title } = Astro.props;
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Special+Elite&family=Oswald:wght@400;700&display=swap" rel="stylesheet" />
    <title>{title}</title>
  </head>
  <body>

    <div class="scanlines"></div>

    <header>
      <div class="header-inner">
        <div class="header-top">
          <a href="/" class="logo">
            <span class="logo-main">SURVIVALIX</span>
            <span class="logo-sub">// GUIDE DE SURVIE DU CITOYEN //</span>
          </a>
          <button class="menu-toggle" id="menuToggle" aria-label="Menu">
            <span></span>
            <span></span>
            <span></span>
          </button>
        </div>
        <nav id="mainNav">
          <ul>
            <li><a href="/manuel">LE MANUEL</a></li>
            <li><a href="/cantine">LA CANTINE</a></li>
            <li><a href="/bazar">LE BAZAR</a></li>
            <li><a href="/atelier">L'ATELIER</a></li>
            <li><a href="/radar">LE RADAR</a></li>
            <li><a href="/outils">LES OUTILS</a></li>
            <li><a href="/survivant" class="cta">QUEL SURVIVANT ES-TU ?</a></li>
          </ul>
        </nav>
      </div>
    </header>

    <div class="hero-band">
      <div class="ticker">
        <div class="ticker-inner">
          <span>⚠ NIVEAU D'ALERTE : MODÉRÉ</span>
          <span class="sep">///</span>
          <span>STOCK EAU : VÉRIFIER</span>
          <span class="sep">///</span>
          <span>RESTEZ INFORMÉS. RESTEZ VIVANTS.</span>
          <span class="sep">///</span>
          <span>KIT 72H : PRÉPARER DÈS MAINTENANT</span>
          <span class="sep">///</span>
          <span>⚠ NIVEAU D'ALERTE : MODÉRÉ</span>
          <span class="sep">///</span>
          <span>STOCK EAU : VÉRIFIER</span>
          <span class="sep">///</span>
          <span>RESTEZ INFORMÉS. RESTEZ VIVANTS.</span>
          <span class="sep">///</span>
          <span>KIT 72H : PRÉPARER DÈS MAINTENANT</span>
          <span class="sep">///</span>
        </div>
      </div>
    </div>

    <main>
      <slot />
    </main>

    <footer>
      <div class="footer-inner">
        <div class="footer-logo">SURVIVALIX</div>
        <p class="footer-tagline">Le site de survie pour les gens normaux.</p>
        <div class="footer-links">
          <a href="/a-propos">À propos</a>
          <a href="/contact">Contact</a>
          <a href="/mentions-legales">Mentions légales</a>
          <a href="/ressources">Ressources</a>
        </div>
        <p class="footer-copy">© 2025 Survivalix — Tous droits réservés</p>
      </div>
    </footer>

  </body>
</html>

<script>
  const toggle = document.getElementById('menuToggle');
  const nav = document.getElementById('mainNav');
  toggle?.addEventListener('click', () => {
    nav?.classList.toggle('open');
    toggle.classList.toggle('active');
  });
</script>

<style>
  *, *::before, *::after {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  :root {
    --noir: #0d0d0d;
    --noir-moyen: #1a1a1a;
    --noir-clair: #242424;
    --ambre: #F5A623;
    --ambre-fonce: #c4811a;
    --kaki: #6B7C45;
    --rouge: #8B2500;
    --creme: #F5E6C8;
    --gris: #888;
    --font-titre: 'Special Elite', cursive;
    --font-nav: 'Oswald', sans-serif;
  }

  html, body {
    width: 100%;
    min-height: 100%;
    background-color: var(--noir);
    color: var(--creme);
    font-family: 'Georgia', serif;
    font-size: 16px;
    line-height: 1.7;
  }

  /* SCANLINES */
  .scanlines {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: repeating-linear-gradient(
      0deg,
      transparent,
      transparent 2px,
      rgba(0,0,0,0.03) 2px,
      rgba(0,0,0,0.03) 4px
    );
    pointer-events: none;
    z-index: 9999;
  }

  /* HEADER */
  header {
    background-color: var(--noir);
    border-bottom: 3px solid var(--ambre);
    padding: 1rem;
    position: sticky;
    top: 0;
    z-index: 100;
  }

  .header-inner {
    max-width: 1300px;
    margin: 0 auto;
  }

  .header-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .logo {
    text-decoration: none;
  }

  .logo-main {
    display: block;
    font-family: var(--font-titre);
    font-size: clamp(1.4rem, 5vw, 2.8rem);
    color: var(--ambre);
    letter-spacing: 4px;
    text-shadow: 0 0 20px rgba(245, 166, 35, 0.4);
  }

  .logo-sub {
    display: block;
    font-family: var(--font-nav);
    font-size: clamp(0.55rem, 1.5vw, 0.7rem);
    color: var(--kaki);
    letter-spacing: 2px;
  }

  /* BURGER */
  .menu-toggle {
    display: flex;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.5rem;
  }

  .menu-toggle span {
    display: block;
    width: 25px;
    height: 2px;
    background-color: var(--ambre);
    transition: all 0.3s;
  }

  .menu-toggle.active span:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }

  .menu-toggle.active span:nth-child(2) {
    opacity: 0;
  }

  .menu-toggle.active span:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }

  /* NAV MOBILE */
  nav {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.3s ease;
  }

  nav.open {
    max-height: 800px;
  }

  nav ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    padding: 0.5rem 0;
    gap: 0;
  }

  nav ul a {
    display: block;
    font-family: var(--font-nav);
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--creme);
    text-decoration: none;
    letter-spacing: 2px;
    padding: 0.4rem 1rem;
    border-left: 3px solid transparent;
    transition: all 0.2s;
    background-color: transparent;
  }

  nav ul a:hover {
    color: var(--ambre);
    border-left-color: var(--ambre);
    background-color: transparent;
  }

  nav ul .cta {
    background-color: var(--ambre);
    color: var(--noir) !important;
    border-left-color: var(--ambre);
    margin-top: 0.4rem;
    text-align: center;
  }

  nav ul .cta:hover {
    background-color: var(--ambre-fonce);
  }

  /* DESKTOP NAV */
  @media (min-width: 768px) {
    .menu-toggle {
      display: none;
    }

    nav {
      max-height: none;
      overflow: visible;
    }

    nav ul {
      flex-direction: row;
      flex-wrap: wrap;
      justify-content: center;
      padding: 0.8rem 0 0;
      gap: 0.2rem;
    }

    nav ul a {
      padding: 0.4rem 0.8rem;
      border-left: none;
      border: 1px solid transparent;
      font-size: 0.78rem;
      background-color: transparent;
    }

    nav ul a:hover {
      border-color: var(--ambre);
      background-color: transparent;
    }

    nav ul .cta {
      margin-top: 0;
      text-align: left;
    }

    .header-top {
      justify-content: center;
    }

    .logo {
      text-align: center;
    }
  }

  /* TICKER */
  .hero-band {
    background-color: var(--ambre);
    overflow: hidden;
    white-space: nowrap;
    padding: 0.35rem 0;
  }

  .ticker {
    display: flex;
    overflow: hidden;
  }

  .ticker-inner {
    display: flex;
    gap: 2rem;
    animation: ticker 20s linear infinite;
    white-space: nowrap;
  }

  .ticker-inner span {
    font-family: var(--font-nav);
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--noir);
    letter-spacing: 2px;
    text-transform: uppercase;
    flex-shrink: 0;
  }

  .ticker-inner .sep {
    color: var(--ambre-fonce);
    opacity: 1;
  }

  @keyframes ticker {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  /* MAIN */
  main {
    max-width: 1300px;
    margin: 0 auto;
    padding: 2rem 1rem;
  }

  @media (min-width: 768px) {
    main {
      padding: 3rem 2rem;
    }
  }

  h1 {
    font-family: var(--font-titre);
    font-size: clamp(1.8rem, 5vw, 2.5rem);
    color: var(--ambre);
    margin-bottom: 1rem;
    letter-spacing: 2px;
  }

  h2 {
    font-family: var(--font-titre);
    font-size: clamp(1.3rem, 4vw, 1.8rem);
    color: var(--creme);
    margin-bottom: 0.8rem;
    border-left: 4px solid var(--ambre);
    padding-left: 1rem;
  }

  p {
    color: var(--creme);
    margin-bottom: 1rem;
    opacity: 0.9;
  }

  a {
    color: var(--ambre);
  }

  ul {
    list-style: none;
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
    margin-top: 1.5rem;
  }

  @media (min-width: 600px) {
    ul {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 900px) {
    ul {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  ul li {
    background-color: var(--noir);
    border: 1px solid #333;
    border-left: 4px solid var(--ambre);
    padding: 1.2rem;
    transition: border-color 0.2s;
  }

  ul li:hover {
    border-left-color: var(--rouge);
  }

  ul li a {
    font-family: var(--font-nav);
    font-size: 1rem;
    font-weight: 700;
    color: var(--creme);
    text-decoration: none;
    letter-spacing: 1px;
  }

  ul li a:hover {
    color: var(--ambre);
  }

  ul li p {
    font-size: 0.85rem;
    margin-top: 0.5rem;
    opacity: 0.7;
  }

  /* FOOTER */
  footer {
    background-color: var(--noir);
    border-top: 3px solid var(--ambre);
    margin-top: 4rem;
    padding: 2rem 1rem;
  }

  .footer-inner {
    max-width: 1300px;
    margin: 0 auto;
    text-align: center;
  }

  .footer-logo {
    font-family: var(--font-titre);
    font-size: 1.8rem;
    color: var(--ambre);
    letter-spacing: 6px;
    margin-bottom: 0.5rem;
  }

  .footer-tagline {
    font-family: var(--font-nav);
    font-size: 0.8rem;
    color: var(--kaki);
    letter-spacing: 2px;
    margin-bottom: 1.5rem;
  }

  .footer-links {
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    gap: 1rem;
    margin-bottom: 1.5rem;
  }

  .footer-links a {
    font-family: var(--font-nav);
    font-size: 0.8rem;
    color: var(--creme);
    text-decoration: none;
    letter-spacing: 1px;
    opacity: 0.7;
    transition: opacity 0.2s;
  }

  .footer-links a:hover {
    opacity: 1;
    color: var(--ambre);
  }

  .footer-copy {
    font-size: 0.75rem;
    color: var(--gris);
    opacity: 0.5;
  }
</style>