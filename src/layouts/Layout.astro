---
import '../styles/global.css';

const { 
  title, 
  description = "Survivalix — Le site de survie pour les gens normaux. Guides pratiques, recettes, outils interactifs et humour post-apo.",
  image = "/og-image.jpg"
} = Astro.props;

const url = Astro.url;
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Special+Elite&family=Oswald:wght@400;700&display=swap" rel="stylesheet" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={url} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={url} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={image} />
    <meta property="og:locale" content="fr_FR" />
    <meta property="og:site_name" content="Survivalix" />
    <meta name="robots" content="index, follow" />
  </head>
  <body>

    <div class="scanlines"></div>

    <header>
      <div class="header-inner">
        <div class="header-top">
          <a href="/" class="logo">
            <span class="logo-main">SURVIVALIX</span>
            <span class="logo-sub">// GUIDE DE SURVIE DU CITOYEN //</span>
          </a>
          <button class="menu-toggle" id="menuToggle" aria-label="Menu">
            <span></span>
            <span></span>
            <span></span>
          </button>
        </div>
        <nav id="mainNav">
          <ul>
            <li><a href="/manuel">LE MANUEL</a></li>
            <li><a href="/cantine">LA CANTINE</a></li>
            <li><a href="/bazar">LE BAZAR</a></li>
            <li><a href="/atelier">L'ATELIER</a></li>
            <li><a href="/radar">LE RADAR</a></li>
            <li><a href="/outils">LES OUTILS</a></li>
            <li><a href="/survivant" class="cta">QUEL SURVIVANT ES-TU ?</a></li>
          </ul>
        </nav>
      </div>
    </header>

    <div class="hero-band">
      <div class="ticker">
        <div class="ticker-inner">
          <span>⚠ NIVEAU D'ALERTE : MODÉRÉ</span>
          <span class="sep">///</span>
          <span>STOCK EAU : VÉRIFIER</span>
          <span class="sep">///</span>
          <span>RESTEZ INFORMÉS. RESTEZ VIVANTS.</span>
          <span class="sep">///</span>
          <span>KIT 72H : PRÉPARER DÈS MAINTENANT</span>
          <span class="sep">///</span>
          <span>⚠ NIVEAU D'ALERTE : MODÉRÉ</span>
          <span class="sep">///</span>
          <span>STOCK EAU : VÉRIFIER</span>
          <span class="sep">///</span>
          <span>RESTEZ INFORMÉS. RESTEZ VIVANTS.</span>
          <span class="sep">///</span>
          <span>KIT 72H : PRÉPARER DÈS MAINTENANT</span>
          <span class="sep">///</span>
        </div>
      </div>
    </div>

    <main>
      <slot />
    </main>

    <footer>
      <div class="footer-inner">
        <div class="footer-logo">SURVIVALIX</div>
        <p class="footer-tagline">Le site de survie pour les gens normaux.</p>
        <div class="footer-links">
          <a href="/a-propos">À propos</a>
          <a href="/contact">Contact</a>
          <a href="/mentions-legales">Mentions légales</a>
          <a href="/ressources">Ressources</a>
        </div>
        <p class="footer-copy">© 2025 Survivalix — Tous droits réservés</p>
      </div>
    </footer>

  </body>
</html>

<script>
  const toggle = document.getElementById('menuToggle');
  const nav = document.getElementById('mainNav');
  toggle?.addEventListener('click', () => {
    nav?.classList.toggle('open');
    toggle.classList.toggle('active');
  });
</script>

<style>
  /* MAIN */
  main {
    max-width: 1300px;
    margin: 0 auto;
    padding: 2rem 1rem;
  }

  @media (min-width: 768px) {
    main { padding: 3rem 2rem; }
  }

  /* TITRES PAGES GÉNÉRIQUES */
  h1 {
    font-size: clamp(1.4rem, 4vw, 2rem);
    margin-bottom: 1rem;
    letter-spacing: 2px;
  }

  h2 {
    font-size: clamp(1.3rem, 4vw, 1.8rem);
    margin-bottom: 0.8rem;
    border-left: 4px solid var(--ambre);
    padding-left: 1rem;
  }

  p {
    color: var(--creme);
    margin-bottom: 1rem;
    opacity: 0.9;
  }

  a { color: var(--ambre); }

  /* GRILLE CARTES */
  ul {
    list-style: none;
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
    margin-top: 1.5rem;
  }

  @media (min-width: 600px) {
    ul { grid-template-columns: repeat(2, 1fr); }
  }

  @media (min-width: 900px) {
    ul { grid-template-columns: repeat(3, 1fr); }
  }

  ul li {
    background-color: var(--noir);
    border: 1px solid #333;
    border-left: 4px solid var(--ambre);
    padding: 1.2rem;
    transition: border-color 0.2s;
  }

  ul li:hover { border-left-color: var(--rouge); }

  ul li a {
    font-family: var(--font-nav);
    font-size: 1rem;
    font-weight: 700;
    color: var(--creme);
    text-decoration: none;
    letter-spacing: 1px;
  }

  ul li a:hover { color: var(--ambre); }

  ul li p {
    font-size: 0.85rem;
    margin-top: 0.5rem;
    opacity: 0.7;
  }
</style>